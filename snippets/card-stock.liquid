{%- comment -%}
  Stock count for product cards on listing grids.
  Renders in Liquid when possible; theme.js hydrates via /products/{handle}.js if needed.
{%- endcomment -%}
{%- liquid
  assign stock_qty = 0
  assign stock_tracked = false

  for variant in product.variants
    if variant.inventory_management == 'shopify'
      assign stock_tracked = true
    endif
    assign stock_qty = stock_qty | plus: variant.inventory_quantity
  endfor
-%}
<span
  class="card__stock{% if stock_tracked and product.available and stock_qty > 0 and stock_qty <= 3 %} is-low{% endif %}"
  data-card-stock
  data-product-handle="{{ product.handle }}"
  {% unless stock_tracked %}hidden{% endunless %}
>
  {%- if stock_tracked -%}
    {%- if product.available -%}
      {%- if stock_qty == 1 -%}
        1 in stock
      {%- else -%}
        {{ stock_qty }} in stock
      {%- endif -%}
    {%- else -%}
      Out of stock
    {%- endif -%}
  {%- endif -%}
</span>
