{%- if settings.loyalty_enable -%}
{%- liquid
  assign balance = loyalty_balance | default: 0 | plus: 0
  assign loyalty_sign_in_url = loyalty_sign_in_url | default: routes.account_login_url
  assign loyalty_register_url = loyalty_register_url | default: routes.account_register_url

  assign points_rate = settings.loyalty_points_per_gbp | default: 1
  assign redeem_points = settings.loyalty_redeem_points | default: 100
  assign redeem_value = settings.loyalty_redeem_value_gbp | default: 5
  assign program_name = settings.loyalty_program_name | default: 'Kori Collectors Club'
  assign redeem_email = settings.loyalty_redeem_email | default: shop.email
  assign points_needed = redeem_points

  if customer and balance < redeem_points
    assign points_needed = redeem_points | minus: balance
  endif

  assign can_redeem = false
  assign active_redeem_code = loyalty_redeem_code | strip
  if customer and balance >= redeem_points and active_redeem_code == blank
    assign can_redeem = true
  endif

  assign rewards_url = pages.rewards.url | default: '/pages/rewards'
  if settings.loyalty_page != blank and settings.loyalty_page.url != blank
    assign rewards_url = settings.loyalty_page.url
  endif
-%}

<div class="loyalty-widget" data-loyalty-widget>
  <button
    type="button"
    class="loyalty-launcher"
    data-open-loyalty-panel
    aria-expanded="false"
    aria-controls="LoyaltyPanel"
    aria-label="Open rewards"
  >
    <span class="loyalty-launcher__glyph" aria-hidden="true">
      <svg class="loyalty-launcher__icon loyalty-launcher__icon--star" viewBox="0 0 24 24" focusable="false">
        <path
          fill="currentColor"
          stroke="currentColor"
          stroke-width="0.85"
          stroke-linejoin="round"
          stroke-linecap="round"
          d="M12 2.2 14.1 8.8 21 8.8 15.5 13.2 17.6 19.8 12 15.8 6.4 19.8 8.5 13.2 3 8.8 9.9 8.8 12 2.2z"
        />
      </svg>
      <svg class="loyalty-launcher__icon loyalty-launcher__icon--close" viewBox="0 0 24 24" focusable="false">
        <path fill="currentColor" d="M18.3 5.7a1 1 0 0 0-1.4 0L12 10.6 7.1 5.7a1 1 0 1 0-1.4 1.4l4.9 4.9-4.9 4.9a1 1 0 1 0 1.4 1.4l4.9-4.9 4.9 4.9a1 1 0 0 0 1.4-1.4L13.4 12l4.9-4.9a1 1 0 0 0 0-1.4z"/>
      </svg>
    </span>
  </button>

  <div class="loyalty-widget__modal" data-loyalty-modal hidden>
    <div class="loyalty-panel__backdrop" data-loyalty-backdrop data-close-loyalty-panel></div>

    <div
      class="loyalty-panel"
      id="LoyaltyPanel"
      data-loyalty-panel
      role="dialog"
      aria-modal="true"
      aria-label="{{ program_name | escape }}"
    >
    <div class="loyalty-panel__header">
      <div>
        <p class="loyalty-panel__eyebrow">Rewards</p>
        <h2 class="loyalty-panel__title">{{ program_name | escape }}</h2>
      </div>
      <button type="button" class="icon-btn" data-close-loyalty-panel aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false" width="20" height="20">
          <path stroke="currentColor" stroke-linecap="round" stroke-width="1.5" d="M5 5l10 10M15 5 5 15"/>
        </svg>
      </button>
    </div>

    <div class="loyalty-panel__body">
      {%- if customer -%}
        <div class="loyalty-panel__balance">
          <span class="loyalty-panel__balance-value" data-loyalty-balance>{{ balance | default: 0 }}</span>
          <span class="loyalty-panel__balance-label">points</span>
        </div>
        {%- if active_redeem_code != blank -%}
          <p class="loyalty-panel__status">Your discount code is ready — use it at checkout.</p>
        {%- elsif can_redeem -%}
          <p class="loyalty-panel__status">You have enough points to redeem a reward.</p>
        {%- else -%}
          <p class="loyalty-panel__status">{{ points_needed }} more points until your next reward.</p>
        {%- endif -%}

        <section class="loyalty-panel__section">
          <h3>Ways to earn</h3>
          <ul class="loyalty-panel__list" role="list">
            <li>
              <strong>{{ points_rate }} point{% if points_rate != 1 %}s{% endif %} per £1 spent</strong>
              <span>Added automatically after your order is paid.</span>
            </li>
            <li>
              <strong>Checkout signed in</strong>
              <span>Points land on your shop account — guest checkout won't earn.</span>
            </li>
          </ul>
        </section>

        <section class="loyalty-panel__section">
          <h3>Ways to redeem</h3>
          {%- render 'loyalty-redeem-card', balance: balance, compact: true, rewards_url: rewards_url -%}
        </section>

        <section
          class="loyalty-panel__section rewards__codes"
          data-loyalty-modal-codes
          {% if active_redeem_code == blank %}hidden{% endif %}
        >
          <h3>Discount code</h3>
          <div class="rewards__codes-list">
            <article class="rewards__code-card" data-loyalty-modal-code-card>
              <div class="rewards__code-card-main">
                <p class="rewards__code-label">Discount code</p>
                <p class="rewards__code-value" data-loyalty-modal-code>{{ active_redeem_code }}</p>
                <p class="rewards__code-meta">Single use · does not expire</p>
              </div>
              <div class="rewards__code-actions">
                <a class="button button--full" href="{% if active_redeem_code != blank %}/discount/{{ active_redeem_code | url_encode }}{% else %}#{% endif %}" data-loyalty-modal-apply>Apply to cart</a>
                <button type="button" class="button button--secondary button--full" data-loyalty-modal-copy>Copy code</button>
              </div>
              <p class="rewards__code-invalid" data-loyalty-modal-copied hidden role="status">Copied.</p>
            </article>
          </div>
        </section>

        <a class="loyalty-panel__link" href="{{ rewards_url }}">Full program details</a>
      {%- else -%}
        <div class="loyalty-panel__guest">
          <p class="loyalty-panel__guest-title">Join free &amp; earn on every order</p>
          <p class="loyalty-panel__guest-text">Create a shop account or sign in to collect points automatically when you buy.</p>
          <div class="loyalty-panel__guest-actions">
            <a class="button button--full" href="{{ loyalty_register_url }}">Create account</a>
            <a class="button button--secondary button--full" href="{{ loyalty_sign_in_url }}">Sign in</a>
          </div>
        </div>

        <section class="loyalty-panel__section">
          <h3>How it works</h3>
          <ul class="loyalty-panel__list" role="list">
            <li>
              <strong>Earn {{ points_rate }} pt per £1</strong>
              <span>On every paid order while signed in.</span>
            </li>
            <li>
              <strong>{{ redeem_points }} points = £{{ redeem_value }} off</strong>
              <span>Redeem when you hit the threshold.</span>
            </li>
          </ul>
        </section>
      {%- endif -%}
    </div>
  </div>
  </div>
</div>
{%- endif -%}
