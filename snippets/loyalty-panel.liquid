{%- liquid
  unless settings.loyalty_enable
    break
  endif

  assign points_key = settings.loyalty_points_metafield | default: 'custom.loyalty_points'
  assign points_parts = points_key | split: '.'
  assign points_ns = points_parts[0]
  assign points_id = points_parts[1]
  assign points_rate = settings.loyalty_points_per_gbp | default: 1
  assign redeem_points = settings.loyalty_redeem_points | default: 100
  assign redeem_value = settings.loyalty_redeem_value_gbp | default: 5
  assign program_name = settings.loyalty_program_name | default: 'Kori Collectors Club'
  assign redeem_email = settings.loyalty_redeem_email | default: shop.email
  assign points_needed = redeem_points

  assign balance = 0
  if customer and points_ns != blank and points_id != blank
    assign balance = customer.metafields[points_ns][points_id].value | default: 0 | plus: 0
  endif

  if customer and balance < redeem_points
    assign points_needed = redeem_points | minus: balance
  endif

  assign can_redeem = false
  if customer and balance >= redeem_points
    assign can_redeem = true
  endif

  assign rewards_url = pages.rewards.url | default: '/pages/rewards'
  if settings.loyalty_page != blank and settings.loyalty_page.url != blank
    assign rewards_url = settings.loyalty_page.url
  endif
-%}

<div class="loyalty-widget" data-loyalty-widget>
  <button
    type="button"
    class="loyalty-launcher"
    data-open-loyalty-panel
    aria-expanded="false"
    aria-controls="LoyaltyPanel"
    aria-label="Open rewards"
  >
    <svg class="loyalty-launcher__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <path fill="currentColor" d="M12 2l2.2 6.8H21l-5.5 4 2.1 6.7L12 15.8 6.4 19.5l2.1-6.7L3 8.8h6.8L12 2z"/>
    </svg>
    {%- if customer and balance > 0 -%}
      <span class="loyalty-launcher__badge">{{ balance }}</span>
    {%- endif -%}
  </button>

  <div class="loyalty-widget__modal" data-loyalty-modal hidden>
    <div class="loyalty-panel__backdrop" data-loyalty-backdrop data-close-loyalty-panel></div>

    <div
      class="loyalty-panel"
      id="LoyaltyPanel"
      data-loyalty-panel
      role="dialog"
      aria-modal="true"
      aria-label="{{ program_name | escape }}"
    >
    <div class="loyalty-panel__header">
      <div>
        <p class="loyalty-panel__eyebrow">Rewards</p>
        <h2 class="loyalty-panel__title">{{ program_name | escape }}</h2>
      </div>
      <button type="button" class="icon-btn" data-close-loyalty-panel aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false" width="20" height="20">
          <path stroke="currentColor" stroke-linecap="round" stroke-width="1.5" d="M5 5l10 10M15 5 5 15"/>
        </svg>
      </button>
    </div>

    <div class="loyalty-panel__body">
      {%- if customer -%}
        <div class="loyalty-panel__balance">
          <span class="loyalty-panel__balance-value" data-loyalty-balance>{{ balance }}</span>
          <span class="loyalty-panel__balance-label">points</span>
        </div>
        {%- if can_redeem -%}
          <p class="loyalty-panel__status">You have enough points to redeem a reward.</p>
        {%- else -%}
          <p class="loyalty-panel__status">{{ points_needed }} more points until your next reward.</p>
        {%- endif -%}

        <section class="loyalty-panel__section">
          <h3>Ways to earn</h3>
          <ul class="loyalty-panel__list" role="list">
            <li>
              <strong>{{ points_rate }} point{% if points_rate != 1 %}s{% endif %} per £1 spent</strong>
              <span>Added automatically after your order is paid.</span>
            </li>
            <li>
              <strong>Checkout signed in</strong>
              <span>Points land on your shop account — guest checkout won't earn.</span>
            </li>
          </ul>
        </section>

        <section class="loyalty-panel__section">
          <h3>Ways to redeem</h3>
          <div class="loyalty-reward{% if can_redeem %} loyalty-reward--ready{% endif %}">
            <div class="loyalty-reward__value">£{{ redeem_value }} off</div>
            <div class="loyalty-reward__cost">{{ redeem_points }} points</div>
            {%- if can_redeem -%}
              <a class="button button--full loyalty-reward__cta" href="mailto:{{ redeem_email | escape }}?subject=Redeem%20{{ redeem_points }}%20points">
                Email to redeem
              </a>
            {%- else -%}
              <p class="loyalty-reward__locked">{{ points_needed }} more points needed</p>
            {%- endif -%}
          </div>
        </section>

        <a class="loyalty-panel__link" href="{{ rewards_url }}">Full program details</a>
      {%- else -%}
        <div class="loyalty-panel__guest">
          <p class="loyalty-panel__guest-title">Join free &amp; earn on every order</p>
          <p class="loyalty-panel__guest-text">Create a shop account or sign in to collect points automatically when you buy.</p>
          <div class="loyalty-panel__guest-actions">
            <a class="button button--full" href="{{ routes.account_register_url }}">Create account</a>
            <a class="button button--secondary button--full" href="{{ routes.account_login_url }}">Sign in</a>
          </div>
        </div>

        <section class="loyalty-panel__section">
          <h3>How it works</h3>
          <ul class="loyalty-panel__list" role="list">
            <li>
              <strong>Earn {{ points_rate }} pt per £1</strong>
              <span>On every paid order while signed in.</span>
            </li>
            <li>
              <strong>{{ redeem_points }} points = £{{ redeem_value }} off</strong>
              <span>Redeem when you hit the threshold.</span>
            </li>
          </ul>
        </section>
      {%- endif -%}
    </div>
  </div>
  </div>
</div>
