{%- comment -%}
  Inline product card markup (avoids GitHub sync dropping snippets).
{%- endcomment -%}
{%- liquid
  assign card_product = product
  assign featured = card_product.selected_or_first_available_variant
  assign stock = featured.inventory_quantity
  assign low = false
  if stock != blank and stock > 0 and stock <= 5
    assign low = true
  endif
  assign image_alt = card_product.featured_image.alt | default: card_product.title
-%}

<a class="card" href="{{ card_product.url }}">
  <div class="card__media">
    {%- unless card_product.available -%}
      <span class="card__badge card__badge--sold">Sold out</span>
    {%- elsif card_product.tags contains 'preorder' or card_product.tags contains 'Preorder' or card_product.tags contains 'pre-order' -%}
      <span class="card__badge">Pre-order</span>
    {%- endif -%}

    {%- if card_product.featured_image -%}
      <img
        src="{{ card_product.featured_image | image_url: width: 480 }}"
        srcset="
          {{ card_product.featured_image | image_url: width: 240 }} 240w,
          {{ card_product.featured_image | image_url: width: 360 }} 360w,
          {{ card_product.featured_image | image_url: width: 480 }} 480w,
          {{ card_product.featured_image | image_url: width: 700 }} 700w
        "
        sizes="(max-width: 749px) 45vw, 23vw"
        alt="{{ image_alt | escape }}"
        width="{{ card_product.featured_image.width }}"
        height="{{ card_product.featured_image.height }}"
        loading="lazy"
      >
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag }}
    {%- endif -%}
  </div>

  <div class="card__body">
    {%- if card_product.vendor != blank -%}
      <div class="card__vendor">{{ card_product.vendor | escape }}</div>
    {%- endif -%}
    <div class="card__title">{{ card_product.title | escape }}</div>
    <div class="card__footer">
      <span class="card__price">
        {%- if card_product.price_varies -%}
          From {{ card_product.price_min | money }}
        {%- else -%}
          {{ card_product.price | money }}
        {%- endif -%}
      </span>
      {%- if settings.show_stock_count -%}
        {%- if stock != blank and stock > 0 -%}
          <span class="card__stock{% if low %} is-low{% endif %}">
            {%- if low -%}{{ stock }} left{%- else -%}In stock{%- endif -%}
          </span>
        {%- elsif card_product.available == false -%}
          <span class="card__stock is-low">Sold out</span>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</a>
