{%- liquid
  assign set_code = product.metafields.custom.set_code
  if set_code == blank
    assign set_code = product.vendor
  endif

  assign is_rare = false
  if product.tags contains 'rare' or product.tags contains 'holo' or product.tags contains 'Rare' or product.tags contains 'Holo'
    assign is_rare = true
  endif

  assign stock_qty = product.selected_or_first_available_variant.inventory_quantity
  assign stock_low = false
  if stock_qty != blank and stock_qty > 0 and stock_qty <= 5
    assign stock_low = true
  endif

  assign image_alt = product.featured_image.alt | default: product.title
-%}

<a
  class="slot{% if is_rare %} slot-rare{% endif %}"
  href="{{ product.url }}"
>
  <div class="slot-card">
    {% if product.featured_image %}
      {{
        product.featured_image
        | image_url: width: 600
        | image_tag: loading: 'lazy', widths: '200, 300, 400, 600', sizes: '(max-width: 900px) 45vw, 250px', alt: image_alt
      }}
    {% else %}
      <div class="slot-art">
        <svg viewBox="0 0 100 100" aria-hidden="true">
          <ellipse cx="50" cy="60" rx="24" ry="20" fill="#5a5870"/>
          <circle cx="42" cy="58" r="4" fill="#f4f1ff"/>
          <circle cx="58" cy="58" r="4" fill="#f4f1ff"/>
        </svg>
      </div>
    {% endif %}
  </div>
  <div class="slot-info">
    <div class="slot-name">{{ product.title | escape }}</div>
    {% if set_code != blank %}
      <div class="slot-set">{{ set_code | escape }}</div>
    {% endif %}
  </div>
  <div class="slot-foot">
    <span class="slot-price">{{ product.price | money }}</span>
    {% if stock_qty != blank and stock_qty > 0 %}
      <span class="slot-stock{% if stock_low %} low{% endif %}">{{ stock_qty }} left</span>
    {% elsif product.available == false %}
      <span class="slot-stock low">Sold out</span>
    {% else %}
      <span class="slot-stock">In stock</span>
    {% endif %}
  </div>
</a>
