{%- comment -%}
  Product tile with optional variant pills, live price, and add to basket.
  Accepts: product, sizes (optional image sizes attr)
{%- endcomment -%}
{%- liquid
  assign card_product = product
  assign image_sizes = sizes | default: '(max-width: 749px) 45vw, 18vw'
  assign current = card_product.selected_or_first_available_variant
  if current == blank
    assign current = card_product.variants.first
  endif
  assign show_pills = false
  unless card_product.has_only_default_variant
    assign show_pills = true
  endunless
  assign image_alt = card_product.featured_image.alt | default: card_product.title
-%}

<article class="card" data-product-card>
  <a class="card__media" href="{{ card_product.url }}">
    {%- if card_product.available == false -%}
      <span class="card__badge card__badge--sold">Sold out</span>
    {%- elsif card_product.tags contains 'preorder' or card_product.tags contains 'Preorder' or card_product.tags contains 'pre-order' -%}
      <span class="card__badge">Pre-order</span>
    {%- endif -%}

    {%- if card_product.featured_image != blank -%}
      <img
        class="card__image"
        src="{{ card_product.featured_image | image_url: width: 480 }}"
        srcset="
          {{ card_product.featured_image | image_url: width: 240 }} 240w,
          {{ card_product.featured_image | image_url: width: 360 }} 360w,
          {{ card_product.featured_image | image_url: width: 480 }} 480w,
          {{ card_product.featured_image | image_url: width: 700 }} 700w
        "
        sizes="{{ image_sizes }}"
        alt="{{ image_alt | escape }}"
        width="{{ card_product.featured_image.width }}"
        height="{{ card_product.featured_image.height }}"
        loading="lazy"
      >
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag }}
    {%- endif -%}
  </a>

  <div class="card__body">
    <a class="card__title" href="{{ card_product.url }}">{{ card_product.title | escape }}</a>

    <div class="card__footer">
      <span class="card__price" data-card-price>
        {{ current.price | money }}
      </span>
    </div>

    {%- if show_pills -%}
      <div class="card__pills" role="radiogroup" aria-label="Variants">
        {%- for variant in card_product.variants -%}
          <button
            type="button"
            class="card__pill{% if variant == current %} is-selected{% endif %}{% unless variant.available %} is-unavailable{% endunless %}"
            data-card-variant
            data-variant-id="{{ variant.id }}"
            data-variant-price="{{ variant.price }}"
            data-variant-available="{{ variant.available }}"
            aria-pressed="{% if variant == current %}true{% else %}false{% endif %}"
            {% unless variant.available %}disabled{% endunless %}
          >
            {{ variant.title | escape }}
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <button
      type="button"
      class="button button--full card__add"
      data-card-add
      data-variant-id="{{ current.id }}"
      {% unless current.available %}disabled{% endunless %}
    >
      {%- if current.available -%}
        Add to basket
      {%- else -%}
        Sold out
      {%- endif -%}
    </button>
  </div>
</article>
