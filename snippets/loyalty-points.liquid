{%- liquid
  assign enabled = enabled | default: settings.loyalty_enable
  assign points_key = settings.loyalty_points_metafield | default: 'custom.loyalty_points'
  assign points_parts = points_key | split: '.'
  assign points_ns = points_parts[0]
  assign points_id = points_parts[1]
  assign balance = 0

  if enabled and customer
    assign points_value = customer.metafields.custom.loyalty_points.value
    if points_value == blank and points_ns != blank and points_id != blank
      assign points_value = customer.metafields[points_ns][points_id].value
    endif
    assign balance = points_value | default: 0 | plus: 0
  endif
-%}
