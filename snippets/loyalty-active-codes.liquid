{%- liquid
  assign redeem_value = redeem_value | default: settings.loyalty_redeem_value_gbp | default: 5
  assign loyalty_redeem_code = active_redeem_code | default: loyalty_redeem_code | strip

  if loyalty_redeem_code == blank and customer
    for tag in customer.tags
      assign tag_stripped = tag | strip
      if tag_stripped contains 'loyalty-code:'
        assign code_from_tag = tag_stripped | split: 'loyalty-code:' | last | strip
        if code_from_tag != blank
          assign loyalty_redeem_code = code_from_tag
        endif
      endif
    endfor
  endif

  if loyalty_redeem_code == blank and customer
    assign redeem_code_key = settings.loyalty_redeem_code_metafield | default: 'custom.loyalty_redeem_code' | strip
    assign redeem_code_parts = redeem_code_key | split: '.'
    assign redeem_code_ns = redeem_code_parts[0] | strip
    assign redeem_code_id = redeem_code_parts[1] | strip
    assign code_from_metafield = blank

    if redeem_code_ns != blank and redeem_code_id != blank
      assign code_from_metafield = customer.metafields[redeem_code_ns][redeem_code_id].value
    endif
    if code_from_metafield == blank
      assign code_from_metafield = customer.metafields.custom.loyalty_redeem_code.value
    endif
    assign loyalty_redeem_code = code_from_metafield | strip
  endif

  assign has_code = false
  if loyalty_redeem_code != blank
    assign has_code = true
  endif
-%}

{%- if customer -%}
  <section
    class="rewards__codes"
    data-loyalty-active-codes
    data-redeem-value="{{ redeem_value }}"
    {% unless has_code %}data-loyalty-active-codes-empty{% endunless %}
  >
    <h2 class="rewards__codes-title">Your active rewards</h2>

    {%- if has_code -%}
      <div class="rewards__codes-list">
        <article class="rewards__code-card" data-loyalty-code-card>
          <div class="rewards__code-card-main">
            <p class="rewards__code-label">Discount code</p>
            <p class="rewards__code-value" data-loyalty-active-code>{{ loyalty_redeem_code | escape }}</p>
            <p class="rewards__code-meta">£{{ redeem_value }} off · single use · does not expire</p>
          </div>
          <div class="rewards__code-actions">
            <a
              class="button button--full"
              href="/discount/{{ loyalty_redeem_code | url_encode }}"
              data-loyalty-active-apply
            >
              Apply to cart
            </a>
            <button type="button" class="button button--secondary button--full" data-loyalty-active-copy>
              Copy code
            </button>
          </div>
          <p class="rewards__code-invalid" data-loyalty-code-invalid hidden role="status">
            This code has already been used or is no longer valid.
          </p>
        </article>
      </div>
    {%- else -%}
      <div class="rewards__codes-empty" data-loyalty-active-codes-placeholder>
        <p>No active discount codes yet. Redeem your points above to get a £{{ redeem_value }} off code.</p>
      </div>
    {%- endif -%}
  </section>
{%- endif -%}
