ad3b0a767e17f03445b26c283ae9dc90a50c5d1ee36bb68dfa9276efb4b5e622:{"__metadata":{"version":0.1},"root":{"steps":[{"step_id":"0b38775c-a88c-44d4-816d-742ea3ed367c","step_position":[0,0],"config_field_values":[{"config_field_id":"type","value":"app--6171699--shopify-forms1063387"}],"task_id":"shopify::admin::metaobject_created","task_version":"0.1","task_type":"TRIGGER","description":null,"note":null,"name":null},{"step_id":"af9e63ac-7638-431f-bb9c-eca10b2880d5","step_position":[0,120],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"882d9204-0d2a-4085-aac1-dcf3aa160be0\",\"lhs\":{\"uuid\":\"b23fca87-f903-4647-87c5-fa1b6748ba6c\",\"parent_uuid\":\"882d9204-0d2a-4085-aac1-dcf3aa160be0\",\"lhs\":{\"uuid\":\"5e8a8d8d-539c-4684-803c-dcfe14d893b9\",\"parent_uuid\":\"b23fca87-f903-4647-87c5-fa1b6748ba6c\",\"value\":\"metaobject.formSubmittedBy.id\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"metaobject.formSubmittedBy.id\"},\"rhs\":{\"uuid\":\"ecb1c687-b201-46d0-8c5d-92a1d793d833\",\"parent_uuid\":\"b23fca87-f903-4647-87c5-fa1b6748ba6c\",\"value\":\"\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:ID\",\"operator\":\"not_empty_and_not_nil?\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null},{"step_id":"eac0383b-aff9-4604-b112-3f23af16f21d","step_position":[0,260],"config_field_values":[{"config_field_id":"input","value":"query {\n  metaobject {\n    formSubmittedBy {\n      id\n      email\n      loyaltyPoints {\n        value\n      }\n      loyaltyRedeemCode {\n        value\n      }\n    }\n  }\n}"},{"config_field_id":"script","value":"const REDEEM_POINTS = 100;\nconst REDEEM_VALUE_GBP = 5;\n\nexport default function main(input) {\n  const customer = input.customer ?? input.metaobject?.formSubmittedBy;\n\n  if (!customer) {\n    return {\n      discountCode: '',\n      newLoyaltyPoints: '0',\n      redeemValueGbp: String(REDEEM_VALUE_GBP),\n      reused: 'false',\n    };\n  }\n\n  const current = Number(customer.loyaltyPoints?.value ?? 0);\n  const existingCode = String(customer.loyaltyRedeemCode?.value ?? '').trim();\n\n  if (existingCode) {\n    return {\n      discountCode: existingCode,\n      newLoyaltyPoints: String(current),\n      redeemValueGbp: String(REDEEM_VALUE_GBP),\n      reused: 'true',\n    };\n  }\n\n  if (current < REDEEM_POINTS) {\n    return {\n      discountCode: '',\n      newLoyaltyPoints: String(current),\n      redeemValueGbp: String(REDEEM_VALUE_GBP),\n      reused: 'false',\n    };\n  }\n\n  const customerId = String(customer.id ?? '').replace(/\\D/g, '') || '0';\n  const code = `KORI-${customerId}-${Date.now().toString(36).toUpperCase()}`;\n  const newBalance = Math.max(0, current - REDEEM_POINTS);\n\n  return {\n    discountCode: code,\n    newLoyaltyPoints: String(newBalance),\n    redeemValueGbp: String(REDEEM_VALUE_GBP),\n    reused: 'false',\n  };\n}"},{"config_field_id":"output_schema","value":"\"The output of Run Code\"\ntype Output {\n  \"Discount code to create (empty if not eligible)\"\n  discountCode: String!\n  \"Customer points balance after redemption\"\n  newLoyaltyPoints: String!\n  \"GBP value of the reward\"\n  redeemValueGbp: String!\n  \"true when customer already has an unused code\"\n  reused: String!\n}"}],"task_id":"shopify::flow::run_code","task_version":"0.1","task_type":"ACTION","description":null,"note":null,"name":"Run code"},{"step_id":"f1651ece-18fa-4a5f-80ed-0c79f4733278","step_position":[0,400],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"75f73895-1c87-464d-b95b-94e71057cc53\",\"lhs\":{\"uuid\":\"9f7b69ee-6048-434c-a94f-9f436c354f20\",\"parent_uuid\":\"75f73895-1c87-464d-b95b-94e71057cc53\",\"lhs\":{\"uuid\":\"57c46c87-d48b-4700-a9e3-4a54be630c7e\",\"parent_uuid\":\"9f7b69ee-6048-434c-a94f-9f436c354f20\",\"value\":\"runCode.discountCode\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"runCode.discountCode\"},\"rhs\":{\"uuid\":\"f3541b1f-46f6-4b12-8ae9-b5b77c675791\",\"parent_uuid\":\"9f7b69ee-6048-434c-a94f-9f436c354f20\",\"value\":\"\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:String\",\"operator\":\"not_empty_and_not_nil?\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null},{"step_id":"e9385c14-acae-44eb-8997-9e95595804d1","step_position":[0,540],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"d42e619e-bc7f-48f8-9c4d-0a9175b0b934\",\"lhs\":{\"uuid\":\"3f49f513-ebc2-4c16-8739-210485e0bba2\",\"parent_uuid\":\"d42e619e-bc7f-48f8-9c4d-0a9175b0b934\",\"lhs\":{\"uuid\":\"147741dd-5114-45ff-a3ef-055ad062b1c3\",\"parent_uuid\":\"3f49f513-ebc2-4c16-8739-210485e0bba2\",\"value\":\"runCode.reused\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"runCode.reused\"},\"rhs\":{\"uuid\":\"1c8e6ef4-ffa1-4492-a011-70f9b828a459\",\"parent_uuid\":\"3f49f513-ebc2-4c16-8739-210485e0bba2\",\"value\":\"false\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:String\",\"operator\":\"==\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null},{"step_id":"5d9fbc00-ad58-4a2e-8b26-de9953f6f564","step_position":[0,680],"config_field_values":[{"config_field_id":"api_call","value":"{\"name\":\"discountCodeBasicCreate\",\"blob\":\"{\\\"basicCodeDiscount\\\":{\\\"title\\\":\\\"Loyalty reward {{ runCode.discountCode }}\\\",\\\"code\\\":\\\"{{ runCode.discountCode }}\\\",\\\"startsAt\\\":\\\"{{ 'now' | date: '%Y-%m-%dT%H:%M:%SZ' }}\\\",\\\"endsAt\\\":\\\"{{ 'now' | date: '%s' | plus: 172800 | date: '%Y-%m-%dT%H:%M:%SZ' }}\\\",\\\"customerSelection\\\":{\\\"customers\\\":{\\\"add\\\":[\\\"{{ metaobject.formSubmittedBy.id }}\\\"]}},\\\"customerGets\\\":{\\\"value\\\":{\\\"discountAmount\\\":{\\\"amount\\\":\\\"{{ runCode.redeemValueGbp }}\\\",\\\"appliesOnEachItem\\\":false}},\\\"items\\\":{\\\"all\\\":true}},\\\"usageLimit\\\":1,\\\"appliesOncePerCustomer\\\":true}}\"}"}],"task_id":"shopify::admin::admin_api_operation","task_version":"0.1","task_type":"ACTION","description":null,"note":null,"name":null},{"step_id":"e98d1e2a-082a-4e88-a233-a8d66648260c","step_position":[0,820],"config_field_values":[{"config_field_id":"customer_id","value":"metaobject.formSubmittedBy.id"},{"config_field_id":"metafield","value":"{\"namespace\":\"custom\",\"key\":\"loyalty_points\",\"type\":\"number_integer\"}"},{"config_field_id":"value","value":"{{ runCode.newLoyaltyPoints }}"}],"task_id":"shopify::admin::add_customer_metafield","task_version":"1.0","task_type":"ACTION","description":null,"note":null,"name":null},{"step_id":"bc43e970-05d0-41ea-acc0-5aaf741351e7","step_position":[0,960],"config_field_values":[{"config_field_id":"customer_id","value":"metaobject.formSubmittedBy.id"},{"config_field_id":"metafield","value":"{\"namespace\":\"custom\",\"key\":\"loyalty_redeem_code\",\"type\":\"single_line_text_field\"}"},{"config_field_id":"value","value":"{{ runCode.discountCode }}"}],"task_id":"shopify::admin::add_customer_metafield","task_version":"1.0","task_type":"ACTION","description":null,"note":null,"name":null}],"links":[{"from_step_id":"0b38775c-a88c-44d4-816d-742ea3ed367c","from_port_id":"output","to_step_id":"af9e63ac-7638-431f-bb9c-eca10b2880d5","to_port_id":"input"},{"from_step_id":"af9e63ac-7638-431f-bb9c-eca10b2880d5","from_port_id":"true","to_step_id":"eac0383b-aff9-4604-b112-3f23af16f21d","to_port_id":"input"},{"from_step_id":