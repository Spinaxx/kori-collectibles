593db7d9499841f812c43ca82eeb12cf74823b3765b1ee575baa6aa4e11b262c:{"__metadata":{"version":0.1},"root":{"steps":[{"step_id":"8de458b1-d37e-458c-9bb5-15c83393762f","step_position":[0,0],"config_field_values":[],"task_id":"shopify::admin::metaobject_created","task_version":"0.1","task_type":"TRIGGER","description":null,"note":null,"name":null},{"step_id":"756292e5-f576-46db-b7a6-0f4d69d0c941","step_position":[0,120],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"01KX1WS1FSCN70Q30Q2S7Y6TVG\",\"lhs\":{\"uuid\":\"01KX1WS1FSQX06MDQB8VJB8Y4V\",\"parent_uuid\":\"01KX1WS1FSCN70Q30Q2S7Y6TVG\",\"lhs\":{\"uuid\":\"01KX1WS1FS51HFBX96YWQJJT71\",\"parent_uuid\":\"01KX1WS1FSQX06MDQB8VJB8Y4V\",\"value\":\"metaobject.formSubmittedBy.id\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"metaobject.formSubmittedBy.id\"},\"rhs\":{\"uuid\":\"01KX1WS1FSBS83QG8DGJB7FE12\",\"parent_uuid\":\"01KX1WS1FSQX06MDQB8VJB8Y4V\",\"value\":\"\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:ID\",\"operator\":\"not_empty_and_not_nil?\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null},{"step_id":"24969ad1-8348-4f70-a4a1-0ab7277da918","step_position":[0,260],"config_field_values":[{"config_field_id":"input","value":"query {\n  metaobject {\n    formSubmittedBy {\n      id\n      email\n      loyaltyPoints {\n        value\n      }\n      loyaltyRedeemCode {\n        value\n      }\n    }\n  }\n}"},{"config_field_id":"script","value":"const REDEEM_POINTS = 100;\nconst REDEEM_VALUE_GBP = 5;\n\nexport default function main(input) {\n  const customer = input.customer ?? input.metaobject?.formSubmittedBy;\n\n  if (!customer) {\n    return {\n      discountCode: '',\n      newLoyaltyPoints: '0',\n      redeemValueGbp: String(REDEEM_VALUE_GBP),\n      reused: 'false',\n    };\n  }\n\n  const current = Number(customer.loyaltyPoints?.value ?? 0);\n  const existingCode = String(customer.loyaltyRedeemCode?.value ?? '').trim();\n\n  if (existingCode) {\n    return {\n      discountCode: existingCode,\n      newLoyaltyPoints: String(current),\n      redeemValueGbp: String(REDEEM_VALUE_GBP),\n      reused: 'true',\n    };\n  }\n\n  if (current < REDEEM_POINTS) {\n    return {\n      discountCode: '',\n      newLoyaltyPoints: String(current),\n      redeemValueGbp: String(REDEEM_VALUE_GBP),\n      reused: 'false',\n    };\n  }\n\n  const customerId = String(customer.id ?? '').replace(/\\D/g, '') || '0';\n  const code = `KORI-${customerId}-${Date.now().toString(36).toUpperCase()}`;\n  const newBalance = Math.max(0, current - REDEEM_POINTS);\n\n  return {\n    discountCode: code,\n    newLoyaltyPoints: String(newBalance),\n    redeemValueGbp: String(REDEEM_VALUE_GBP),\n    reused: 'false',\n  };\n}"},{"config_field_id":"output_schema","value":"\"The output of Run Code\"\ntype Output {\n  \"Discount code to create (empty if not eligible)\"\n  discountCode: String!\n  \"Customer points balance after redemption\"\n  newLoyaltyPoints: String!\n  \"GBP value of the reward\"\n  redeemValueGbp: String!\n  \"true when customer already has an unused code\"\n  reused: String!\n}"}],"task_id":"shopify::flow::run_code","task_version":"0.1","task_type":"ACTION","description":null,"note":null,"name":"Run code"},{"step_id":"dae8fc70-535e-485f-b722-047953ae361b","step_position":[0,400],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"01KX1WS1FSKHPYM1MYWMKX9Y24\",\"lhs\":{\"uuid\":\"01KX1WS1FSAC26XS8F7QG2Y7F0\",\"parent_uuid\":\"01KX1WS1FSKHPYM1MYWMKX9Y24\",\"lhs\":{\"uuid\":\"01KX1WS1FSV581P4R976H3QFXP\",\"parent_uuid\":\"01KX1WS1FSAC26XS8F7QG2Y7F0\",\"value\":\"runCode.discountCode\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"runCode.discountCode\"},\"rhs\":{\"uuid\":\"01KX1WS1FSVJFY9GJNH34R3CSP\",\"parent_uuid\":\"01KX1WS1FSAC26XS8F7QG2Y7F0\",\"value\":\"\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:String\",\"operator\":\"not_empty_and_not_nil?\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null},{"step_id":"e8f441d0-3556-47c8-ad44-d2ea4fda3a35","step_position":[0,540],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"01KX1WS1FSATCHN2CMYDRM6KPP\",\"lhs\":{\"uuid\":\"01KX1WS1FS3R6BSFRRJMPBHPWK\",\"parent_uuid\":\"01KX1WS1FSATCHN2CMYDRM6KPP\",\"lhs\":{\"uuid\":\"01KX1WS1FSXQTC6J2YXEF1F9C0\",\"parent_uuid\":\"01KX1WS1FS3R6BSFRRJMPBHPWK\",\"value\":\"runCode.reused\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"runCode.reused\"},\"rhs\":{\"uuid\":\"01KX1WS1FSN23QQK0ZDF8SYG0S\",\"parent_uuid\":\"01KX1WS1FS3R6BSFRRJMPBHPWK\",\"value\":\"false\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:String\",\"operator\":\"==\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null},{"step_id":"b079eca7-e713-4667-bfc3-5e64991bc05e","step_position":[0,680],"config_field_values":[{"config_field_id":"api_call","value":"{\"name\":\"discountCodeBasicCreate\",\"blob\":\"{\\\"basicCodeDiscount\\\":{\\\"title\\\":\\\"Loyalty reward {{ runCode.discountCode }}\\\",\\\"code\\\":\\\"{{ runCode.discountCode }}\\\",\\\"startsAt\\\":\\\"{{ 'now' | date: '%Y-%m-%dT%H:%M:%SZ' }}\\\",\\\"endsAt\\\":\\\"{{ 'now' | date: '%s' | plus: 172800 | date: '%Y-%m-%dT%H:%M:%SZ' }}\\\",\\\"customerSelection\\\":{\\\"customers\\\":{\\\"add\\\":[\\\"{{ metaobject.formSubmittedBy.id }}\\\"]}},\\\"customerGets\\\":{\\\"value\\\":{\\\"discountAmount\\\":{\\\"amount\\\":\\\"{{ runCode.redeemValueGbp }}\\\",\\\"appliesOnEachItem\\\":false}},\\\"items\\\":{\\\"all\\\":true}},\\\"usageLimit\\\":1,\\\"appliesOncePerCustomer\\\":true}}\"}"}],"task_id":"shopify::admin::admin_api_operation","task_version":"0.1","task_type":"ACTION","description":null,"note":null,"name":null},{"step_id":"2a653934-140f-4f38-bfe7-b5c39c76dedf","step_position":[0,820],"config_field_values":[{"config_field_id":"customer_id","value":"{\"value\":\"{{ metaobject.formSubmittedBy.id }}\",\"default_value\":\"metaobject.formSubmittedBy.id\"}"},{"config_field_id":"metafield","value":"{\"namespace\":\"custom\",\"key\":\"loyalty_points\",\"type\":\"number_integer\"}"},{"config_field_id":"value","value":"{{ runCode.newLoyaltyPoints }}"}],"task_id":"shopify::admin::add_customer_metafield","task_version":"1.0","task_type":"ACTION","description":null,"note":null,"name":null},{"step_id":"21d51749-7e4f-488f-9f15-dbb78bd053b0","step_position":[0,960],"config_field_values":[{"config_field_id":"customer_id","value":"{\"value\":\"{{ metaobject.formSubmittedBy.id }}\",\"default_value\":\"metaobject.formSubmittedBy.id\"}"},{"config_field_id":"metafield","value":"{\"namespace\":\"custom\",\"key\":\"loyalty_redeem_code\",\"type\":\"single_line_text_field\"}"},{"config_field_id":"value","value":"{{ runCode.discountCode }}"}],"task_id":"shopify::admin::add_customer_metafield","task_version":"1.0","task_type":"ACTION","description":null,"note":null,"name":null}],"links":[{"from_step_id":"8de458b1-d37e-458c-9bb5-15c83393762f","from_port_id":"output","to_step_id":"756292e5-f576-46db-b7a6-0f4d69d0c941","to_port_id":"input"},{"from_step_id":"756292e5-f576-46db-b7a6-0f4d69d0c941","from_port_id":"true","to_step_id":"24969ad1-8348-4f70-a4a1-0ab7277da918","to_port_id":"input"},{"from_step_id":"24969ad1-8348-4f70-a4a1-0ab7277da918","from_port_id":"output","to_step_id":"dae8fc70-535e-485f-b722-047953ae361b","to_port_id":"inpu