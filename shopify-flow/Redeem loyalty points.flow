c115e3042749f94e68376d258de22a78c4e6f55f15d1469f6b777afe7ad1a25d:{"__metadata":{"version":0.1},"root":{"steps":[{"step_id":"24037c4a-bb84-46a9-b290-dc36966ef136","step_position":[0,0],"config_field_values":[{"config_field_id":"type","value":"app--6171699--shopify-forms1063387"}],"task_id":"shopify::admin::metaobject_created","task_version":"0.1","task_type":"TRIGGER","description":null,"note":null,"name":null},{"step_id":"36bdcd1b-0c10-4010-b976-1e220e9a9b89","step_position":[0,120],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"85f47ced-7513-492d-9adf-ed7056a3cdc7\",\"lhs\":{\"uuid\":\"0a5ae187-7887-495a-a278-5c4b22cfc4f2\",\"parent_uuid\":\"85f47ced-7513-492d-9adf-ed7056a3cdc7\",\"lhs\":{\"uuid\":\"bf8e8535-a52f-4918-bc7f-3b3399756b1e\",\"parent_uuid\":\"0a5ae187-7887-495a-a278-5c4b22cfc4f2\",\"value\":\"metaobject.formSubmittedBy.id\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"metaobject.formSubmittedBy.id\"},\"rhs\":{\"uuid\":\"f1b3d592-d023-4912-b283-d598e6f039e5\",\"parent_uuid\":\"0a5ae187-7887-495a-a278-5c4b22cfc4f2\",\"value\":\"\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:ID\",\"operator\":\"not_empty_and_not_nil?\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null},{"step_id":"c08a173e-0a19-4739-975d-205cb6383f1f","step_position":[0,260],"config_field_values":[{"config_field_id":"input","value":"query {\n  metaobject {\n    formSubmittedBy {\n      id\n      email\n      loyaltyPoints {\n        value\n      }\n      loyaltyRedeemCode {\n        value\n      }\n    }\n  }\n}"},{"config_field_id":"script","value":"const REDEEM_POINTS = 100;\nconst REDEEM_VALUE_GBP = 5;\n\nexport default function main(input) {\n  const customer = input.customer ?? input.metaobject?.formSubmittedBy;\n\n  if (!customer) {\n    return {\n      discountCode: '',\n      newLoyaltyPoints: '0',\n      redeemValueGbp: String(REDEEM_VALUE_GBP),\n      reused: 'false',\n    };\n  }\n\n  const current = Number(customer.loyaltyPoints?.value ?? 0);\n  const existingCode = String(customer.loyaltyRedeemCode?.value ?? '').trim();\n\n  if (existingCode) {\n    return {\n      discountCode: existingCode,\n      newLoyaltyPoints: String(current),\n      redeemValueGbp: String(REDEEM_VALUE_GBP),\n      reused: 'true',\n    };\n  }\n\n  if (current < REDEEM_POINTS) {\n    return {\n      discountCode: '',\n      newLoyaltyPoints: String(current),\n      redeemValueGbp: String(REDEEM_VALUE_GBP),\n      reused: 'false',\n    };\n  }\n\n  const customerId = String(customer.id ?? '').replace(/\\D/g, '') || '0';\n  const code = `KORI-${customerId}-${Date.now().toString(36).toUpperCase()}`;\n  const newBalance = Math.max(0, current - REDEEM_POINTS);\n\n  return {\n    discountCode: code,\n    newLoyaltyPoints: String(newBalance),\n    redeemValueGbp: String(REDEEM_VALUE_GBP),\n    reused: 'false',\n  };\n}"},{"config_field_id":"output_schema","value":"\"The output of Run Code\"\ntype Output {\n  \"Discount code to create (empty if not eligible)\"\n  discountCode: String!\n  \"Customer points balance after redemption\"\n  newLoyaltyPoints: String!\n  \"GBP value of the reward\"\n  redeemValueGbp: String!\n  \"true when customer already has an unused code\"\n  reused: String!\n}"}],"task_id":"shopify::flow::run_code","task_version":"0.1","task_type":"ACTION","description":null,"note":null,"name":"Run code"},{"step_id":"5a1c445f-8624-4223-aba0-5ddf0018fc05","step_position":[0,400],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"487b2405-f392-4530-a0ce-1802fc8e8196\",\"lhs\":{\"uuid\":\"620e376e-99c4-4a42-8924-0537a64a26e8\",\"parent_uuid\":\"487b2405-f392-4530-a0ce-1802fc8e8196\",\"lhs\":{\"uuid\":\"d9973274-8830-41e9-a2e3-f5e729abafc8\",\"parent_uuid\":\"620e376e-99c4-4a42-8924-0537a64a26e8\",\"value\":\"runCode.discountCode\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"runCode.discountCode\"},\"rhs\":{\"uuid\":\"f945735d-3a26-4595-b55d-34607f539d75\",\"parent_uuid\":\"620e376e-99c4-4a42-8924-0537a64a26e8\",\"value\":\"\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:String\",\"operator\":\"not_empty_and_not_nil?\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null},{"step_id":"18ad8312-8d05-41b4-b9c5-39a19dd2e858","step_position":[0,540],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"dbd79ffb-47ba-4bb6-b678-890423ca1db9\",\"lhs\":{\"uuid\":\"c51c6dc4-1899-4276-9317-7ead9e4b55ed\",\"parent_uuid\":\"dbd79ffb-47ba-4bb6-b678-890423ca1db9\",\"lhs\":{\"uuid\":\"7179f2ee-5c8b-48b1-80ed-057b5b61290f\",\"parent_uuid\":\"c51c6dc4-1899-4276-9317-7ead9e4b55ed\",\"value\":\"runCode.reused\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"runCode.reused\"},\"rhs\":{\"uuid\":\"13f9239f-22f1-4454-8a8b-31ab0625611e\",\"parent_uuid\":\"c51c6dc4-1899-4276-9317-7ead9e4b55ed\",\"value\":\"false\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:String\",\"operator\":\"==\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null}],"links":[{"from_step_id":"24037c4a-bb84-46a9-b290-dc36966ef136","from_port_id":"output","to_step_id":"36bdcd1b-0c10-4010-b976-1e220e9a9b89","to_port_id":"input"},{"from_step_id":"36bdcd1b-0c10-4010-b976-1e220e9a9b89","from_port_id":"true","to_step_id":"c08a173e-0a19-4739-975d-205cb6383f1f","to_port_id":"input"},{"from_step_id":"c08a173e-0a19-4739-975d-205cb6383f1f","from_port_id":"output","to_step_id":"5a1c445f-8624-4223-aba0-5ddf0018fc05","to_port_id":"input"},{"from_step_id":"5a1c445f-8624-4223-aba0-5ddf0018fc05","from_port_id":"true","to_step_id":"18ad8312-8d05-41b4-b9c5-39a19dd2e858","to_port_id":"input"}],"patched_fields":[{"id":"9d1f9dee-b2a5-45b1-adfe-f68b3020a2be","handle":"formSubmittedBy","field":"formSubmittedBy","patched_type":"metaobject_1063387","arguments":"{\"key\":\"form_submitted_by\"}","merchant_configured":false},{"id":"2829e3c1-8e3e-4b65-9ab4-7bc1543d4888","handle":"formSubmittedAt","field":"formSubmittedAt","patched_type":"metaobject_1063387","arguments":"{\"key\":\"form_submitted_at\"}","merchant_configured":false},{"id":"a4876054-cc44-4282-9e9e-30e27db29a45","handle":"formDisplayName","field":"formDisplayName","patched_type":"metaobject_1063387","arguments":"{\"key\":\"form_display_name\"}","merchant_configured":false},{"id":"754f3c71-8349-4805-912d-f0688e66a79b","handle":"loyaltyPoints","field":"metafield","patched_type":"Customer","arguments":"{\"key\":\"loyalty_points\",\"namespace\":\"custom\"}","merchant_configured":true},{"id":"bd79bae6-c639-436a-bc67-3e3848b48e18","handle":"loyaltyRedeemCode","field":"metafield","patched_type":"Customer","arguments":"{\"key\":\"loyalty_redeem_code\",\"namespace\":\"custom\"}","merchant_configured":true}],"workflow_name":"Redeem loyalty points"}}