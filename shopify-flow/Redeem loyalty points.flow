5cb109b537e5c67c9cb1a4cf1fe0b8fa74cec750b5d9e33cca784fd2feda0056:{"__metadata":{"version":0.1},"root":{"steps":[{"step_id":"1b3e8cd1-5d06-4995-8a62-75c570d2a44c","step_position":[0,0],"config_field_values":[{"config_field_id":"type","value":"app--6171699--shopify-forms1063387"}],"task_id":"shopify::admin::metaobject_created","task_version":"0.1","task_type":"TRIGGER","description":null,"note":null,"name":null},{"step_id":"6f38c519-004c-475c-8da1-df8a952353bc","step_position":[0,120],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"61da7077-2182-423f-9513-187ef6e86e35\",\"lhs\":{\"uuid\":\"104b29d1-0690-4216-a939-24f6e5037723\",\"parent_uuid\":\"61da7077-2182-423f-9513-187ef6e86e35\",\"lhs\":{\"uuid\":\"a0c3a33c-af1e-400a-b8dd-b3fc18ea20e0\",\"parent_uuid\":\"104b29d1-0690-4216-a939-24f6e5037723\",\"value\":\"metaobject.formSubmittedBy.id\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"metaobject.formSubmittedBy.id\"},\"rhs\":{\"uuid\":\"2cad1e83-1966-4e56-be00-4fd40a6ead51\",\"parent_uuid\":\"104b29d1-0690-4216-a939-24f6e5037723\",\"value\":\"\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:ID\",\"operator\":\"not_empty_and_not_nil?\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null},{"step_id":"33e8276e-45c5-42a0-91bd-9151f9a64abb","step_position":[0,260],"config_field_values":[{"config_field_id":"input","value":"query {\n  metaobject {\n    formSubmittedBy {\n      id\n      email\n      loyaltyPoints {\n        value\n      }\n      loyaltyRedeemCode {\n        value\n      }\n    }\n  }\n}"},{"config_field_id":"script","value":"const REDEEM_POINTS = 100;\nconst REDEEM_VALUE_GBP = 5;\n\nexport default function main(input) {\n  const customer = input.customer ?? input.metaobject?.formSubmittedBy;\n\n  if (!customer) {\n    return {\n      discountCode: '',\n      newLoyaltyPoints: '0',\n      redeemValueGbp: String(REDEEM_VALUE_GBP),\n      reused: 'false',\n    };\n  }\n\n  const current = Number(customer.loyaltyPoints?.value ?? 0);\n  const existingCode = String(customer.loyaltyRedeemCode?.value ?? '').trim();\n\n  if (existingCode) {\n    return {\n      discountCode: existingCode,\n      newLoyaltyPoints: String(current),\n      redeemValueGbp: String(REDEEM_VALUE_GBP),\n      reused: 'true',\n    };\n  }\n\n  if (current < REDEEM_POINTS) {\n    return {\n      discountCode: '',\n      newLoyaltyPoints: String(current),\n      redeemValueGbp: String(REDEEM_VALUE_GBP),\n      reused: 'false',\n    };\n  }\n\n  const customerId = String(customer.id ?? '').replace(/\\D/g, '') || '0';\n  const code = `KORI-${customerId}-${Date.now().toString(36).toUpperCase()}`;\n  const newBalance = Math.max(0, current - REDEEM_POINTS);\n\n  return {\n    discountCode: code,\n    newLoyaltyPoints: String(newBalance),\n    redeemValueGbp: String(REDEEM_VALUE_GBP),\n    reused: 'false',\n  };\n}"},{"config_field_id":"output_schema","value":"\"The output of Run Code\"\ntype Output {\n  \"Discount code to create (empty if not eligible)\"\n  discountCode: String!\n  \"Customer points balance after redemption\"\n  newLoyaltyPoints: String!\n  \"GBP value of the reward\"\n  redeemValueGbp: String!\n  \"true when customer already has an unused code\"\n  reused: String!\n}"}],"task_id":"shopify::flow::run_code","task_version":"0.1","task_type":"ACTION","description":null,"note":null,"name":"Run code"},{"step_id":"3c84fc32-e3a0-46d2-bd58-a63ae5ac291f","step_position":[0,400],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"70d05b66-09c8-44e5-ade0-646ddec60f10\",\"lhs\":{\"uuid\":\"069c8f42-7b47-4432-a5b0-d8a99c79f601\",\"parent_uuid\":\"70d05b66-09c8-44e5-ade0-646ddec60f10\",\"lhs\":{\"uuid\":\"00407f9a-fb91-448b-aa8d-44430ff669ae\",\"parent_uuid\":\"069c8f42-7b47-4432-a5b0-d8a99c79f601\",\"value\":\"runCode.discountCode\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"runCode.discountCode\"},\"rhs\":{\"uuid\":\"0e66d48a-84b7-40a7-846c-82f90ac3cbf3\",\"parent_uuid\":\"069c8f42-7b47-4432-a5b0-d8a99c79f601\",\"value\":\"\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:String\",\"operator\":\"not_empty_and_not_nil?\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null},{"step_id":"84bfe9ef-ab3a-4d96-b975-bc68eb170b34","step_position":[0,540],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"1860ef52-13eb-4b1f-80e5-f38fb1d8435a\",\"lhs\":{\"uuid\":\"b41cfe9c-8376-479f-aac7-8c41e91c649e\",\"parent_uuid\":\"1860ef52-13eb-4b1f-80e5-f38fb1d8435a\",\"lhs\":{\"uuid\":\"f11f88ba-3677-475e-88f7-40b3af2dfd3d\",\"parent_uuid\":\"b41cfe9c-8376-479f-aac7-8c41e91c649e\",\"value\":\"runCode.reused\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"runCode.reused\"},\"rhs\":{\"uuid\":\"806e1098-03d5-47fd-a8cd-108e515aa32a\",\"parent_uuid\":\"b41cfe9c-8376-479f-aac7-8c41e91c649e\",\"value\":\"false\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:String\",\"operator\":\"==\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null}],"links":[{"from_step_id":"1b3e8cd1-5d06-4995-8a62-75c570d2a44c","from_port_id":"output","to_step_id":"6f38c519-004c-475c-8da1-df8a952353bc","to_port_id":"input"},{"from_step_id":"6f38c519-004c-475c-8da1-df8a952353bc","from_port_id":"true","to_step_id":"33e8276e-45c5-42a0-91bd-9151f9a64abb","to_port_id":"input"