9160549ec81213437c803107552f3f2afa7dde08ec3aa90e555c68404053fb95:{"__metadata":{"version":0.1},"root":{"steps":[{"step_id":"4e4cd777-400e-4cb7-aed0-e7f1bf873a3c","step_position":[0,0],"config_field_values":[],"task_id":"shopify::admin::metaobject_created","task_version":"0.1","task_type":"TRIGGER","description":null,"note":null,"name":null},{"step_id":"d569eca3-23c0-46b7-9fc5-f7435f4cbfcc","step_position":[0,120],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"01KX1WS1FRANGKPR0YQT8DHY3C\",\"lhs\":{\"uuid\":\"01KX1WS1FR6J5VS2184DTXGR8Q\",\"parent_uuid\":\"01KX1WS1FRANGKPR0YQT8DHY3C\",\"lhs\":{\"uuid\":\"01KX1WS1FR5J4E0WT7P4H03YB8\",\"parent_uuid\":\"01KX1WS1FR6J5VS2184DTXGR8Q\",\"value\":\"metaobject.formSubmittedBy.id\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"metaobject.formSubmittedBy.id\"},\"rhs\":{\"uuid\":\"01KX1WS1FR81AXFQ0WQYP3CFJ6\",\"parent_uuid\":\"01KX1WS1FR6J5VS2184DTXGR8Q\",\"value\":\"\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:ID\",\"operator\":\"not_empty_and_not_nil?\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null},{"step_id":"7bc4a7e0-a41e-41cb-a22e-99a893daad82","step_position":[0,260],"config_field_values":[{"config_field_id":"input","value":"query {\n  metaobject {\n    formSubmittedBy {\n      id\n      email\n      loyaltyPoints {\n        value\n      }\n      loyaltyRedeemCode {\n        value\n      }\n    }\n  }\n}"},{"config_field_id":"script","value":"const REDEEM_POINTS = 100;\nconst REDEEM_VALUE_GBP = 5;\n\nexport default function main(input) {\n  const customer = input.customer ?? input.metaobject?.formSubmittedBy;\n\n  if (!customer) {\n    return {\n      discountCode: '',\n      newLoyaltyPoints: '0',\n      redeemValueGbp: String(REDEEM_VALUE_GBP),\n      reused: 'false',\n    };\n  }\n\n  const current = Number(customer.loyaltyPoints?.value ?? 0);\n  const existingCode = String(customer.loyaltyRedeemCode?.value ?? '').trim();\n\n  if (existingCode) {\n    return {\n      discountCode: existingCode,\n      newLoyaltyPoints: String(current),\n      redeemValueGbp: String(REDEEM_VALUE_GBP),\n      reused: 'true',\n    };\n  }\n\n  if (current < REDEEM_POINTS) {\n    return {\n      discountCode: '',\n      newLoyaltyPoints: String(current),\n      redeemValueGbp: String(REDEEM_VALUE_GBP),\n      reused: 'false',\n    };\n  }\n\n  const customerId = String(customer.id ?? '').replace(/\\D/g, '') || '0';\n  const code = `KORI-${customerId}-${Date.now().toString(36).toUpperCase()}`;\n  const newBalance = Math.max(0, current - REDEEM_POINTS);\n\n  return {\n    discountCode: code,\n    newLoyaltyPoints: String(newBalance),\n    redeemValueGbp: String(REDEEM_VALUE_GBP),\n    reused: 'false',\n  };\n}"},{"config_field_id":"output_schema","value":"\"The output of Run Code\"\ntype Output {\n  \"Discount code to create (empty if not eligible)\"\n  discountCode: String!\n  \"Customer points balance after redemption\"\n  newLoyaltyPoints: String!\n  \"GBP value of the reward\"\n  redeemValueGbp: String!\n  \"true when customer already has an unused code\"\n  reused: String!\n}"}],"task_id":"shopify::flow::run_code","task_version":"0.1","task_type":"ACTION","description":null,"note":null,"name":"Run code"},{"step_id":"bb040b62-fba9-4b93-84d3-9723047edf22","step_position":[0,400],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"01KX1WS1FSGSFWQPP86WFE4612\",\"lhs\":{\"uuid\":\"01KX1WS1FSP5BF68D6X3D38YF1\",\"parent_uuid\":\"01KX1WS1FSGSFWQPP86WFE4612\",\"lhs\":{\"uuid\":\"01KX1WS1FSGHHX0TS7B4ZJ4896\",\"parent_uuid\":\"01KX1WS1FSP5BF68D6X3D38YF1\",\"value\":\"runCode.discountCode\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"runCode.discountCode\"},\"rhs\":{\"uuid\":\"01KX1WS1FS0ZJW44E4RZMN3GYK\",\"parent_uuid\":\"01KX1WS1FSP5BF68D6X3D38YF1\",\"value\":\"\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:String\",\"operator\":\"not_empty_and_not_nil?\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null},{"step_id":"5e780528-8325-41c2-909c-7f0e3ebc8801","step_position":[0,540],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"01KX1WS1FS56V56HAB1GCT7JD1\",\"lhs\":{\"uuid\":\"01KX1WS1FSMV006WCDV2H5MSWQ\",\"parent_uuid\":\"01KX1WS1FS56V56HAB1GCT7JD1\",\"lhs\":{\"uuid\":\"01KX1WS1FSX6MQJFX4752JRW07\",\"parent_uuid\":\"01KX1WS1FSMV006WCDV2H5MSWQ\",\"value\":\"runCode.reused\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"runCode.reused\"},\"rhs\":{\"uuid\":\"01KX1WS1FSS5ZYGMMQ55KHJEBQ\",\"parent_uuid\":\"01KX1WS1FSMV006WCDV2H5MSWQ\",\"value\":\"false\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:String\",\"operator\":\"==\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null}],"links":[{"from_step_id":"4e4cd777-400e-4cb7-aed0-e7f1bf873a3c","from_port_id":"output","to_step_id":"d569eca3-23c0-46b7-9fc5-f7435f4cbfcc","to_port_id":"input"},{"from_step_id":"d569eca3-23c0-46b7-9fc5-f7435f4cbfcc","from_port_id":"true","to_step_id":"7bc4a7e0-a41e-41cb-a22e-99a893daad82","to_port_id":"input"},{"from_step_id":"7bc4a7e0-a41e-41cb-a22e-99a893daad82","from_port_id":"output","to_step_id":"bb040b62-fba9-4b93-84d3-9723047edf22","to_port_id":"input"},{"from_step_id":"bb040b62-fba9-4b93-84d3-9723047edf22","from_port_id":"true","to_step_id":"5e780528-8325-41c2-909c-7f0e3ebc8801","to_port_id":"input"}],"patched_fields":[{"id":"efa738b6-d6aa-4bbd-b15e-f53b519f809c","handle":"loyaltyPoints","field":"metafield","patched_type":"Customer","arguments":"{\"key\":\"loyalty_points\",\"namespace\":\"custom\"}","merchant_configured":true},{"id":"a25ec712-717a-403a-9a1b-6330df3b7c55","handle":"loyaltyRedeemCode","field":"metafield","patched_type":"Customer","arguments":"{\"key\":\"loyalty_redeem_code\",\"namespace\":\"custom\"}","merchant_configured":true}],"variables":[],"note":null,"vertical_layout_enabled":true,"workflow_name":"Redeem loyalty points"}}