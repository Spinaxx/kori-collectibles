{% doc %}
  @prompt
    Add custom CSS to center the image collage block (block ID: ai_gen_block_b66160f_9yPdYK) horizontally within its section container. The block is set to 65% width and should be centered using margin: 0 auto or equivalent CSS.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-center-block-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-center-block-{{ ai_gen_id }} [data-block-id="{{ block.settings.target_block_id }}"] {
    margin-left: auto;
    margin-right: auto;
  }
{% endstyle %}

<custom-center-block-{{ ai_gen_id }}
  class="ai-center-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
</custom-center-block-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomCenterBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const targetBlockId = '{{ block.settings.target_block_id }}';
        if (!targetBlockId) return;

        const targetBlock = document.querySelector(`[data-block-id="${targetBlockId}"]`);
        if (targetBlock) {
          targetBlock.style.marginLeft = 'auto';
          targetBlock.style.marginRight = 'auto';
        }
      }
    }

    customElements.define('custom-center-block-{{ ai_gen_id }}', CustomCenterBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Center block CSS",
  "settings": [
    {
      "type": "text",
      "id": "target_block_id",
      "label": "Target block ID",
      "default": "ai_gen_block_b66160f_9yPdYK"
    }
  ],
  "presets": [
    {
      "name": "Center block CSS"
    }
  ]
}
{% endschema %}
