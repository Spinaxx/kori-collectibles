[
  {
    "name": "theme_info",
    "theme_name": "Kori Collectibles",
    "theme_version": "1.0.0",
    "theme_author": "Kori Collectibles",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 60,
        "max": 220,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 140
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_bg",
        "label": "Background",
        "default": "#0c0e14"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Surface",
        "default": "#151821"
      },
      {
        "type": "color",
        "id": "color_surface_2",
        "label": "Surface elevated",
        "default": "#1c2030"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#f2f0eb"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted text",
        "default": "#9a97a8"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent",
        "default": "#2dd4bf"
      },
      {
        "type": "color",
        "id": "color_accent_2",
        "label": "Accent secondary",
        "default": "#f5a524"
      },
      {
        "type": "color",
        "id": "color_danger",
        "label": "Alert / low stock",
        "default": "#ff6b5a"
      },
      {
        "type": "color",
        "id": "color_button",
        "label": "Button",
        "default": "#f2f0eb"
      },
      {
        "type": "color",
        "id": "color_button_text",
        "label": "Button text",
        "default": "#0c0e14"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1000,
        "max": 1400,
        "step": 20,
        "unit": "px",
        "label": "Page width",
        "default": 1240
      },
      {
        "type": "checkbox",
        "id": "show_stock_count",
        "label": "Show stock counts on cards",
        "default": true
      },
      {
        "type": "text",
        "id": "currency_note",
        "label": "Currency note",
        "default": "Prices in GBP"
      }
    ]
  },
  {
    "name": "Social",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_discord",
        "label": "Discord URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook URL"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "cart_notes_enable",
        "label": "Enable cart notes",
        "default": false
      },
      {
        "type": "text",
        "id": "empty_cart_message",
        "label": "Empty cart message",
        "default": "Your cart is empty \u2014 the binder awaits."
      },
      {
        "type": "text",
        "id": "cart_free_shipping_threshold",
        "label": "Free shipping threshold (GBP, blank to hide)",
        "default": "40"
      }
    ]
  }
]
