<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_bg }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Manrope:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    >

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    <meta property="og:site_name" content="{{ shop.name }}">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:title" content="{{ page_title | escape }}">
    {%- if page_description -%}
      <meta property="og:description" content="{{ page_description | escape }}">
    {%- endif -%}
    <meta property="og:type" content="{% if request.page_type == 'product' %}product{% else %}website{% endif %}">
    {%- if request.page_type == 'product' and product.featured_image -%}
      <meta property="og:image" content="http:{{ product.featured_image | image_url: width: 1200 }}">
      <meta property="og:image:secure_url" content="https:{{ product.featured_image | image_url: width: 1200 }}">
    {%- elsif settings.share_image != blank -%}
      <meta property="og:image" content="http:{{ settings.share_image | image_url: width: 1200 }}">
      <meta property="og:image:secure_url" content="https:{{ settings.share_image | image_url: width: 1200 }}">
    {%- endif -%}
    <meta name="twitter:card" content="summary_large_image">

    {% style %}
      :root {
        --color-bg: {{ settings.color_bg | default: '#0c0e14' }};
        --color-surface: {{ settings.color_surface | default: '#151821' }};
        --color-surface-2: {{ settings.color_surface_2 | default: '#1c2030' }};
        --color-text: {{ settings.color_text | default: '#f2f0eb' }};
        --color-muted: {{ settings.color_muted | default: '#9a97a8' }};
        --color-accent: {{ settings.color_accent | default: '#2dd4bf' }};
        --color-accent-2: {{ settings.color_accent_2 | default: '#f5a524' }};
        --color-danger: {{ settings.color_danger | default: '#ff6b5a' }};
        --color-button: {{ settings.color_button | default: '#f2f0eb' }};
        --color-button-text: {{ settings.color_button_text | default: '#0c0e14' }};
        --page-width-setting: {{ settings.page_width | default: 1360 }}px;
        --logo-width: {{ settings.logo_width | default: 168 }}px;
      }

      /* Critical paint — visible even if theme.css is slow or blocked */
      body {
        margin: 0;
        background: {{ settings.color_bg | default: '#0c0e14' }};
        color: {{ settings.color_text | default: '#f2f0eb' }};
        font-family: 'Manrope', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }
    {% endstyle %}

    <script>
      (function () {
        var ua = navigator.userAgent || '';
        if (/Instagram|FBAN|FBAV|FB_IAB|Line\//i.test(ua)) {
          document.documentElement.classList.add('in-app-browser');
        }
      })();
    </script>

    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {{ content_for_header }}

    {%- liquid
      assign rewards_url = pages.rewards.url | default: '/pages/rewards'
      if settings.loyalty_page != blank and settings.loyalty_page.url != blank
        assign rewards_url = settings.loyalty_page.url
      endif
    -%}
    {%- include 'loyalty-balance' -%}
    {%- include 'loyalty-auth-urls' -%}
  </head>

  <body
    {% if customer %}data-customer-logged-in="true" data-loyalty-balance="{{ loyalty_balance | default: 0 }}"{% endif %}
    data-rewards-url="{{ rewards_url | escape }}"
  >
    <a class="skip-link" href="#MainContent">Skip to content</a>

    {%- assign main_menu = linklists[settings.menu] -%}
    {%- if main_menu == blank -%}
      {%- assign main_menu = linklists['main-menu'] -%}
    {%- endif -%}

    {% sections 'header-group' %}

    <header class="header" data-header>
      <div class="page-width header__bar">
        <button
          type="button"
          class="icon-btn menu-toggle"
          data-open-menu
          aria-expanded="false"
          aria-controls="MenuDrawer"
          aria-label="Open menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false" width="20" height="20">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.5 5.5h13M3.5 10h13M3.5 14.5h13"/>
          </svg>
        </button>

        <a class="header__logo" href="{{ routes.root_url }}">
          <img
            class="header__logo-img"
            src="{{ 'kori-collectibles-logo.png' | asset_url }}"
            alt="{{ shop.name | escape }}"
            width="459"
            height="274"
            loading="eager"
          >
        </a>

        <nav class="header__nav" aria-label="Primary">
          <ul class="nav-list" role="list">
            {%- if main_menu != blank and main_menu.links.size > 0 -%}
              {%- for link in main_menu.links -%}
                <li>
                  {%- if link.links != blank -%}
                    <details class="nav-item">
                      <summary class="nav-link">
                        <span>{{ link.title | escape }}</span>
                        <svg class="nav-caret" viewBox="0 0 10 6" aria-hidden="true"><path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                      </summary>
                      <div class="mega">
                        <div class="mega__grid">
                          {%- for child in link.links -%}
                            {%- liquid
                              assign child_title_lc = child.title | downcase
                              assign child_new_tab = false
                              if child_title_lc contains 'buy' and child_title_lc contains 'sell'
                                assign child_new_tab = true
                              endif
                            -%}
                            <div>
                              <a
                                class="mega__title"
                                href="{{ child.url }}"
                                {% if child_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                              >
                                {{ child.title | escape }}
                              </a>
                              {%- if child.links != blank -%}
                                {%- for grand in child.links -%}
                                  {%- liquid
                                    assign grand_title_lc = grand.title | downcase
                                    assign grand_new_tab = false
                                    if grand_title_lc contains 'buy' and grand_title_lc contains 'sell'
                                      assign grand_new_tab = true
                                    endif
                                  -%}
                                  <a
                                    class="mega__link"
                                    href="{{ grand.url }}"
                                    {% if grand_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                                  >
                                    {{ grand.title | escape }}
                                  </a>
                                {%- endfor -%}
                              {%- endif -%}
                            </div>
                          {%- endfor -%}
                        </div>
                      </div>
                    </details>
                  {%- else -%}
                    {%- liquid
                      assign link_title_lc = link.title | downcase
                      assign link_new_tab = false
                      if link_title_lc contains 'buy' and link_title_lc contains 'sell'
                        assign link_new_tab = true
                      endif
                    -%}
                    <a
                      class="nav-link{% if link.current %} is-active{% endif %}"
                      href="{{ link.url }}"
                      {% if link.current %}aria-current="page"{% endif %}
                      {% if link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                    >
                      {{ link.title | escape }}
                    </a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            {%- else -%}
              <li><a class="nav-link" href="{{ routes.all_products_collection_url }}">Shop</a></li>
              <li><a class="nav-link" href="{{ routes.collections_url }}">Collections</a></li>
              <li><a class="nav-link" href="{{ routes.cart_url }}">Cart</a></li>
            {%- endif -%}
          </ul>
        </nav>

        <div class="header__actions">
          <button
            type="button"
            class="icon-btn"
            data-open-account
            aria-expanded="false"
            aria-controls="AccountDrawer"
            aria-label="{{ 'general.accessibility.account' | t }}"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false" width="20" height="20">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 10.5a3.25 3.25 0 1 0 0-6.5 3.25 3.25 0 0 0 0 6.5ZM4.75 16.25v-.9c0-1.95 1.58-3.53 3.53-3.53h3.44c1.95 0 3.53 1.58 3.53 3.53v.9"/>
            </svg>
          </button>
          <button type="button" class="icon-btn" data-open-search aria-label="Search">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false" width="20" height="20">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.5 13.5a5 5 0 1 0 0-10 5 5 0 0 0 0 10ZM14.5 14.5 12 12"/>
            </svg>
          </button>
          <button
            type="button"
            class="icon-btn"
            data-open-cart
            aria-label="Cart"
            aria-expanded="false"
            aria-controls="CartDrawer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false" width="20" height="20">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M3.4 6.9h13.2v8c0 .57-.22 1.11-.62 1.51-.4.4-.94.63-1.51.63H5.53c-.57 0-1.11-.23-1.51-.63a2.14 2.14 0 0 1-.62-1.51zM8.8 3h2.4c.62 0 1.21.25 1.65.68.43.44.68 1.03.68 1.66v1.56H6.5V5.34c0-.63.24-1.22.68-1.66A2.3 2.3 0 0 1 8.8 3z"/>
            </svg>
            <span class="cart-count" data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
          </button>
        </div>
      </div>
    </header>

    <div class="drawer" id="MenuDrawer" data-drawer="menu" hidden>
      <div class="drawer__backdrop" data-close-menu></div>
      <div class="drawer__panel" role="dialog" aria-modal="true" aria-label="Menu">
        <div class="drawer__top">
          <span class="drawer__title">Menu</span>
          <button type="button" class="icon-btn" data-close-menu aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false" width="20" height="20">
              <path stroke="currentColor" stroke-linecap="round" stroke-width="1.5" d="M5 5l10 10M15 5 5 15"/>
            </svg>
          </button>
        </div>
        <nav class="drawer-nav" aria-label="Mobile">
          <ul role="list">
            {%- if main_menu != blank and main_menu.links.size > 0 -%}
              {%- for link in main_menu.links -%}
                <li>
                  {%- if link.links != blank -%}
                    <details>
                      <summary>{{ link.title | escape }}</summary>
                      <ul role="list">
                        {%- for child in link.links -%}
                          {%- liquid
                            assign child_title_lc = child.title | downcase
                            assign child_new_tab = false
                            if child_title_lc contains 'buy' and child_title_lc contains 'sell'
                              assign child_new_tab = true
                            endif
                          -%}
                          <li>
                            <a
                              href="{{ child.url }}"
                              {% if child_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                            >
                              {{ child.title | escape }}
                            </a>
                            {%- for grand in child.links -%}
                              {%- liquid
                                assign grand_title_lc = grand.title | downcase
                                assign grand_new_tab = false
                                if grand_title_lc contains 'buy' and grand_title_lc contains 'sell'
                                  assign grand_new_tab = true
                                endif
                              -%}
                              <a
                                href="{{ grand.url }}"
                                {% if grand_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                              >
                                {{ grand.title | escape }}
                              </a>
                            {%- endfor -%}
                          </li>
                        {%- endfor -%}
                      </ul>
                    </details>
                  {%- else -%}
                    {%- liquid
                      assign link_title_lc = link.title | downcase
                      assign link_new_tab = false
                      if link_title_lc contains 'buy' and link_title_lc contains 'sell'
                        assign link_new_tab = true
                      endif
                    -%}
                    <a
                      href="{{ link.url }}"
                      {% if link_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                    >
                      {{ link.title | escape }}
                    </a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            {%- else -%}
              <li><a href="{{ routes.all_products_collection_url }}">Shop</a></li>
              <li><a href="{{ routes.collections_url }}">Collections</a></li>
              <li><a href="{{ routes.cart_url }}" data-open-cart>Cart</a></li>
            {%- endif -%}
          </ul>
        </nav>
      </div>
    </div>

    {%- liquid
      assign cart_threshold_cents = settings.cart_free_shipping_threshold | times: 100
    -%}
    <div
      class="cart-drawer"
      id="CartDrawer"
      data-cart-drawer
      hidden
      data-money-format="{{ shop.money_format | escape }}"
      data-cart-url="{{ routes.cart_url }}"
      data-checkout-url="{{ routes.cart_url }}?checkout"
      data-free-shipping-threshold="{{ cart_threshold_cents }}"
      data-empty-message="{{ settings.empty_cart_message | escape }}"
    >
      <div class="cart-drawer__backdrop" data-close-cart></div>
      <div class="cart-drawer__panel" role="dialog" aria-modal="true" aria-label="Cart">
        <div class="cart-drawer__top">
          <span class="cart-drawer__title">Your cart</span>
          <button type="button" class="icon-btn" data-close-cart aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false" width="20" height="20">
              <path stroke="currentColor" stroke-linecap="round" stroke-width="1.5" d="M5 5l10 10M15 5 5 15"/>
            </svg>
          </button>
        </div>

        <div class="cart-drawer__body" data-cart-contents>
          {%- if cart.item_count == 0 -%}
            <div class="cart-drawer__empty">
              <p>{{ settings.empty_cart_message }}</p>
              <button type="button" class="button" data-close-cart style="margin-top:1rem;">Continue shopping</button>
            </div>
          {%- else -%}
            <ul class="cart-drawer__items" role="list">
              {%- for item in cart.items -%}
                <li class="cart-drawer__item" data-key="{{ item.key }}">
                  <a class="cart-drawer__media" href="{{ item.url }}">
                    {%- if item.image -%}
                      {{ item.image | image_url: width: 160 | image_tag: loading: 'lazy', alt: item.product.title }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag }}
                    {%- endif -%}
                  </a>
                  <div class="cart-drawer__details">
                    <a class="cart-drawer__name" href="{{ item.url }}">{{ item.product.title | escape }}</a>
                    {%- unless item.product.has_only_default_variant -%}
                      <div class="cart-drawer__meta">{{ item.variant.title | escape }}</div>
                    {%- endunless -%}
                    <div class="cart-drawer__meta">{{ item.original_price | money }}</div>
                    <div class="cart-drawer__row">
                      <div class="cart-drawer__qty">
                        <button type="button" data-cart-qty="-1" data-key="{{ item.key }}" aria-label="Decrease quantity">-</button>
                        <input
                          type="number"
                          min="0"
                          value="{{ item.quantity }}"
                          aria-label="Quantity"
                          data-cart-qty-input
                          data-key="{{ item.key }}"
                        >
                        <button type="button" data-cart-qty="1" data-key="{{ item.key }}" aria-label="Increase quantity">+</button>
                      </div>
                      <div class="cart-drawer__line mono">{{ item.final_line_price | money }}</div>
                    </div>
                    <button type="button" class="cart-drawer__remove" data-cart-remove data-key="{{ item.key }}">Remove</button>
                  </div>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>

        <div class="cart-drawer__footer" data-cart-footer {% if cart.item_count == 0 %}hidden{% endif %}>
          {%- if settings.cart_free_shipping_threshold != blank -%}
            <div class="cart-drawer__shipping" data-cart-shipping>
              {%- if cart.total_price >= cart_threshold_cents -%}
                You've unlocked free UK delivery
              {%- else -%}
                {%- assign remaining = cart_threshold_cents | minus: cart.total_price -%}
                Spend {{ remaining | money }} more for free UK delivery
              {%- endif -%}
            </div>
          {%- endif -%}
          {%- if settings.loyalty_enable -%}
            {%- if customer -%}
              {%- assign earn_preview = cart.total_price | times: settings.loyalty_points_per_gbp | divided_by: 100 -%}
              <div class="cart-drawer__loyalty" data-cart-loyalty data-points-rate="{{ settings.loyalty_points_per_gbp }}">
                <p class="cart-drawer__loyalty-line">
                  You'll earn <strong data-cart-loyalty-earn>{{ earn_preview }}</strong> points on this order.
                  {%- if loyalty_balance > 0 -%}
                    Balance: <strong data-loyalty-balance>{{ loyalty_balance | default: 0 }}</strong> pts.
                  {%- endif -%}
                </p>
                <a class="cart-drawer__loyalty-link" href="{{ rewards_url }}">View rewards</a>
              </div>
            {%- else -%}
              <div class="cart-drawer__loyalty cart-drawer__loyalty--guest">
                <a class="cart-drawer__loyalty-link" href="{{ loyalty_sign_in_url }}">Sign in</a> to earn rewards on this order.
              </div>
            {%- endif -%}
          {%- endif -%}
          <div class="cart-drawer__subtotal">
            <span>Subtotal</span>
            <strong data-cart-subtotal>{{ cart.total_price | money }}</strong>
          </div>
          <p class="cart-drawer__note">Taxes and shipping calculated at checkout</p>
          <div class="cart-drawer__actions">
            <a class="button button--secondary button--full" href="{{ routes.cart_url }}">View cart</a>
            <form action="{{ routes.cart_url }}" method="post">
              <button type="submit" name="checkout" class="button button--full">Checkout</button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <div class="search-modal" data-search-modal hidden>
      <div class="search-modal__box" role="dialog" aria-modal="true" aria-label="Search">
        <form
          action="{{ routes.search_url }}"
          method="get"
          role="search"
          class="search-modal__form"
          data-predictive-search
          data-search-url="{{ routes.search_url }}"
          data-suggest-url="{{ routes.predictive_search_url }}"
        >
          <input type="hidden" name="type" value="product">
          <input type="hidden" name="options[prefix]" value="last">
          <input type="hidden" name="options[unavailable_products]" value="last">
          <input
            class="search-modal__input"
            type="search"
            name="q"
            placeholder="Search cards, sets, sealed..."
            aria-label="Search"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            data-predictive-input
            aria-controls="PredictiveResults"
            aria-autocomplete="list"
          >
          <button type="submit" class="button">Search</button>
          <button type="button" class="icon-btn" data-close-search aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" aria-hidden="true" focusable="false" width="20" height="20">
              <path stroke="currentColor" stroke-linecap="round" stroke-width="1.5" d="M5 5l10 10M15 5 5 15"/>
            </svg>
          </button>
        </form>

        <div
          class="predictive"
          id="PredictiveResults"
          data-predictive-results
          hidden
          role="listbox"
          aria-label="Search suggestions"
        ></div>
      </div>
    </div>

    <main id="MainContent" class="main-content" role="main">
      {%- if request.path contains '/policies/shipping-policy' -%}
        {% section 'shipping' %}
      {%- elsif request.path contains '/policies/refund-policy' -%}
        {% section 'returns' %}
      {%- else -%}
        {{ content_for_layout }}
      {%- endif -%}
    </main>

    {%- assign shop_menu = linklists[settings.footer_shop_menu] -%}
    {%- assign help_menu = linklists[settings.footer_help_menu] -%}

    <footer class="footer">
      <div class="page-width">
        <div class="footer__grid">
          <div>
            <div class="footer__brand">{{ settings.footer_brand_name | default: shop.name }}</div>
            {%- if settings.footer_about != blank -%}
              <p class="footer__about">{{ settings.footer_about }}</p>
            {%- endif -%}
          </div>

          <div>
            <h4>Shop</h4>
            {%- if shop_menu != blank and shop_menu.links.size > 0 -%}
              {%- for link in shop_menu.links -%}
                <a href="{{ link.url }}">{{ link.title }}</a>
              {%- endfor -%}
            {%- else -%}
              <a href="{{ routes.all_products_collection_url }}">All products</a>
              <a href="{{ routes.collections_url }}">Collections</a>
            {%- endif -%}
          </div>

          <div>
            <h4>Help</h4>
            {%- if help_menu != blank and help_menu.links.size > 0 -%}
              {%- for link in help_menu.links -%}
                <a href="{{ link.url }}">{{ link.title }}</a>
              {%- endfor -%}
            {%- else -%}
              <a href="/pages/contact">Contact</a>
              <a href="{{ shop.shipping_policy.url | default: '/policies/shipping-policy' }}">Shipping</a>
              <a href="{{ shop.refund_policy.url | default: '/policies/refund-policy' }}">Returns</a>
            {%- endif -%}
          </div>

          <div>
            <h4>Follow</h4>
            <div class="footer__social">
              {%- if settings.social_instagram != blank -%}
                <a
                  class="footer__social-link"
                  href="{{ settings.social_instagram }}"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Instagram"
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" width="18" height="18">
