{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ 'gift_cards.issued.subtext' | t | default: 'Gift card' }} — {{ shop.name }}</title>
    {{ 'theme.css' | asset_url | stylesheet_tag }}
  </head>
  <body>
    <main class="page-width section" style="text-align:center;">
      <h1>{{ shop.name }}</h1>
      <p class="product__desc" style="margin:1rem auto;">Gift card</p>
      <p class="product__price">{{ gift_card.balance | money }}</p>
      {%- if gift_card.enabled == false or gift_card.expired -%}
        <p>{{ 'products.unavailable' | t }}</p>
      {%- endif -%}
      <p style="font-family:var(--font-mono);letter-spacing:0.08em;margin-top:1.5rem;">{{ gift_card.code | format_code }}</p>
    </main>
  </body>
</html>
