{%- if section.settings.show_announcement -%}
  <div class="announcement">
    <div class="page-width announcement__inner">
      {%- for block in section.blocks -%}
        {%- if block.type == 'announcement' -%}
          <span {{ block.shopify_attributes }}>
            {{ block.settings.text }}
            {%- if block.settings.highlight != blank -%}
              <b>{{ block.settings.highlight }}</b>
            {%- endif -%}
            {{ block.settings.text_after }}
          </span>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

<header class="header" data-header>
  <div class="page-width header__bar">
    <button
      type="button"
      class="icon-btn menu-toggle"
      data-open-menu
      aria-expanded="false"
      aria-controls="MenuDrawer"
      aria-label="Open menu"
    >
      {% render 'icon-menu' %}
    </button>

    <a class="header__logo" href="{{ routes.root_url }}">
      {%- if settings.logo != blank -%}
        {{
          settings.logo
          | image_url: width: 400
          | image_tag:
            widths: '120, 180, 240, 320, 400',
            sizes: '(max-width: 749px) 140px, 180px',
            alt: shop.name,
            loading: 'eager'
        }}
      {%- else -%}
        <span class="logo-mark" aria-hidden="true"></span>
        <span>{{ section.settings.logo_text | default: shop.name }}</span>
      {%- endif -%}
    </a>

    <nav class="header__nav" aria-label="Primary">
      <ul class="nav-list" role="list">
        {%- if section.settings.menu != blank -%}
          {%- for link in section.settings.menu.links -%}
            <li>
              {%- if link.links != blank -%}
                <details class="nav-item">
                  <summary class="nav-link">
                    <span>{{ link.title | escape }}</span>
                    <svg class="nav-caret" viewBox="0 0 10 6" aria-hidden="true"><path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </summary>
                  <div class="mega">
                    <div class="mega__grid">
                      {%- for child in link.links -%}
                        <div>
                          <a class="mega__title" href="{{ child.url }}">{{ child.title | escape }}</a>
                          {%- if child.links != blank -%}
                            {%- for grand in child.links -%}
                              <a class="mega__link" href="{{ grand.url }}">{{ grand.title | escape }}</a>
                            {%- endfor -%}
                          {%- endif -%}
                        </div>
                      {%- endfor -%}
                    </div>
                  </div>
                </details>
              {%- else -%}
                <a
                  class="nav-link{% if link.current %} is-active{% endif %}"
                  href="{{ link.url }}"
                  {% if link.current %}aria-current="page"{% endif %}
                >
                  {{ link.title | escape }}
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        {%- else -%}
          <li><a class="nav-link" href="{{ routes.all_products_collection_url }}">Shop</a></li>
          <li><a class="nav-link" href="{{ routes.collections_url }}">Collections</a></li>
          <li><a class="nav-link" href="{{ routes.cart_url }}">Cart</a></li>
        {%- endif -%}
      </ul>
    </nav>

    <div class="header__actions">
      <button type="button" class="icon-btn" data-open-search aria-label="Search">
        {% render 'icon-search' %}
      </button>
      <a href="{{ routes.cart_url }}" class="icon-btn" aria-label="Cart">
        {% render 'icon-cart' %}
        {%- if cart.item_count > 0 -%}
          <span class="cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </div>
</header>

<div class="drawer" id="MenuDrawer" data-drawer="menu" hidden>
  <div class="drawer__backdrop" data-close-menu></div>
  <div class="drawer__panel" role="dialog" aria-modal="true" aria-label="Menu">
    <div class="drawer__top">
      <span class="drawer__title">Menu</span>
      <button type="button" class="icon-btn" data-close-menu aria-label="Close">
        {% render 'icon-close' %}
      </button>
    </div>
    <nav class="drawer-nav" aria-label="Mobile">
      <ul role="list">
        {%- if section.settings.menu != blank -%}
          {%- for link in section.settings.menu.links -%}
            <li>
              {%- if link.links != blank -%}
                <details>
                  <summary>{{ link.title | escape }}</summary>
                  <ul role="list">
                    {%- for child in link.links -%}
                      <li>
                        <a href="{{ child.url }}">{{ child.title | escape }}</a>
                        {%- for grand in child.links -%}
                          <a href="{{ grand.url }}">{{ grand.title | escape }}</a>
                        {%- endfor -%}
                      </li>
                    {%- endfor -%}
                  </ul>
                </details>
              {%- else -%}
                <a href="{{ link.url }}">{{ link.title | escape }}</a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="{{ routes.all_products_collection_url }}">Shop</a></li>
          <li><a href="{{ routes.collections_url }}">Collections</a></li>
          <li><a href="{{ routes.cart_url }}">Cart</a></li>
        {%- endif -%}
      </ul>
    </nav>
  </div>
</div>

<div class="search-modal" data-search-modal hidden>
  <div class="search-modal__box" role="dialog" aria-modal="true" aria-label="Search">
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-modal__form">
      <input type="hidden" name="type" value="product">
      <input
        class="search-modal__input"
        type="search"
        name="q"
        placeholder="{{ 'search.placeholder' | t }}"
        aria-label="Search"
      >
      <button type="submit" class="button">{{ 'search.submit' | t }}</button>
      <button type="button" class="icon-btn" data-close-search aria-label="Close">
        {% render 'icon-close' %}
      </button>
    </form>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text fallback",
      "default": "Kori Collectibles"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text before highlight",
          "default": "Free UK delivery over "
        },
        {
          "type": "text",
          "id": "highlight",
          "label": "Highlight",
          "default": "£40"
        },
        {
          "type": "text",
          "id": "text_after",
          "label": "Text after highlight",
          "default": ""
        }
      ]
    }
  ]
}
{% endschema %}
