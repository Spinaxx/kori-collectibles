{%- liquid
  assign min_price_cents = section.settings.min_price | default: 5 | times: 100
  assign source = section.settings.source_collection
  assign pool_limit = section.settings.pool_size | default: 50
  assign candidate_count = 0

  if source != blank
    assign product_list = source.products
  else
    assign product_list = collections.all.products
  endif
-%}

{{ 'kori-hero.css' | asset_url | stylesheet_tag }}
<script src="{{ 'kori-hero.js' | asset_url }}" defer="defer"></script>

<div class="kori-hero color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width kori-hero__inner">
    <div class="kori-hero__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="kori-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      <h1 class="kori-hero__heading">
        {{ section.settings.heading_line_1 | escape }}
        {%- if section.settings.heading_line_2 != blank -%}
          <br>
          {{ section.settings.heading_line_2 | escape }}
          {%- if section.settings.heading_em != blank -%}
            <em>{{ section.settings.heading_em | escape }}</em>
          {%- endif -%}
          {{ section.settings.heading_after | escape }}
        {%- endif -%}
      </h1>

      {%- if section.settings.text != blank -%}
        <p class="kori-hero__text">{{ section.settings.text | escape }}</p>
      {%- endif -%}

      <div class="kori-hero__actions">
        {%- if section.settings.primary_label != blank -%}
          <a href="{{ section.settings.primary_link }}" class="button">
            {{ section.settings.primary_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          <a href="{{ section.settings.secondary_link }}" class="button button--secondary">
            {{ section.settings.secondary_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="kori-hero__stage">
      <a
        class="kori-hero__card"
        id="KoriHeroCard"
        href="{{ routes.all_products_collection_url }}"
        data-kori-hero-card
        aria-label="Featured single"
      >
        <span class="kori-hero__shine" id="KoriHeroShine"></span>
        <img
          data-kori-hero-image
          class="kori-hero__image"
          alt="{{ section.settings.fallback_name | escape }}"
          width="280"
          height="392"
          {% if section.settings.fallback_image != blank %}
            src="{{ section.settings.fallback_image | image_url: width: 800 }}"
          {% else %}
            src=""
            hidden
          {% endif %}
        >
        <span
          class="kori-hero__placeholder"
          data-kori-hero-fallback
          {% if section.settings.fallback_image != blank %}hidden{% endif %}
        >
          {{ 'product-1' | placeholder_svg_tag }}
        </span>
        <span class="kori-hero__holo" aria-hidden="true"></span>
      </a>
    </div>
  </div>

  <script type="application/json" data-kori-hero-candidates>
    [
      {%- for product in product_list -%}
        {%- if candidate_count >= pool_limit -%}{%- break -%}{%- endif -%}

        {%- liquid
          assign type_down = product.type | downcase | strip
          assign tags_joined = product.tags | join: ',' | downcase

          assign is_sealed = false
          if type_down contains 'sealed' or type_down contains 'booster' or type_down == 'etb' or type_down contains 'elite trainer' or type_down contains 'bundle' or type_down contains 'tin' or type_down contains 'case'
            assign is_sealed = true
          endif
          if tags_joined contains 'sealed' or tags_joined contains 'booster-box' or tags_joined contains 'etb'
            assign is_sealed = true
          endif

          assign is_single = false
          if source != blank and is_sealed == false
            assign is_single = true
          elsif type_down == 'single' or type_down == 'singles' or type_down == 'card' or type_down == 'cards'
            assign is_single = true
          elsif tags_joined contains 'single' or tags_joined contains 'singles'
            assign is_single = true
          endif
          if is_sealed
            assign is_single = false
          endif
        -%}

        {%- if is_single and product.available and product.price > min_price_cents and product.featured_image -%}
          {%- assign candidate_count = candidate_count | plus: 1 -%}
          {%- unless candidate_count == 1 -%},{%- endunless -%}
          {
            "title": {{ product.title | json }},
            "url": {{ product.url | json }},
            "image": {{ product.featured_image | image_url: width: 800 | json }}
          }
        {%- endif -%}
      {%- endfor -%}
    ]
  </script>
</div>

{% schema %}
{
  "name": "Kori hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Independent Pokémon TCG shop"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading line 1",
      "default": "The hunt is"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading line 2",
      "default": "half the "
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading highlight",
      "default": "foil"
    },
    {
      "type": "text",
      "id": "heading_after",
      "label": "After highlight",
      "default": "."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Singles, sealed product, and grading — sourced and condition-checked by people who actually play."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Browse singles"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Shop sealed product"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Featured card"
    },
    {
      "type": "collection",
      "id": "source_collection",
      "label": "Singles collection",
      "info": "Best option. If blank, products tagged/typed as singles are used."
    },
    {
      "type": "range",
      "id": "min_price",
      "min": 1,
      "max": 50,
      "step": 1,
      "unit": "£",
      "label": "Minimum price",
      "default": 5
    },
    {
      "type": "range",
      "id": "pool_size",
      "min": 10,
      "max": 50,
      "step": 5,
      "label": "Candidate pool size",
      "default": 50
    },
    {
      "type": "text",
      "id": "fallback_name",
      "label": "Fallback alt text",
      "default": "Featured single"
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Fallback image"
    }
  ],
  "presets": [
    {
      "name": "Kori hero"
    }
  ]
}
{% endschema %}
