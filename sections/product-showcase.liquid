{%- liquid
  assign source = section.settings.collection
  assign limit = section.settings.products_to_show | default: 8
  assign product_filter = section.settings.product_filter | default: 'singles'
  if source != blank
    assign products = source.products
  else
    assign products = collections.all.products
  endif

  assign shown = 0
-%}

<section class="section">
  <div class="page-width">
    <div class="section-head">
      <div>
        <h2>{{ section.settings.heading | escape }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p>{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.show_view_all and source != blank -%}
        <a class="section-link" href="{{ source.url }}">View all</a>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- for product in products -%}
        {%- liquid
          if shown >= limit
            break
          endif

          assign type_lc = product.type | downcase | strip
          assign tags_lc = product.tags | join: ',' | downcase
          assign sealed = false
          if type_lc contains 'sealed' or type_lc contains 'booster' or type_lc contains 'etb' or type_lc contains 'elite trainer' or tags_lc contains 'sealed'
            assign sealed = true
          endif

          if product_filter == 'singles' and sealed
            continue
          endif
          if product_filter == 'sealed' and sealed == false
            continue
          endif

          assign shown = shown | plus: 1
        -%}
        {%- render 'product-card', product: product, sizes: '(max-width: 749px) 45vw, 23vw' -%}
      {%- endfor -%}

      {%- if shown == 0 -%}
        <div class="empty-state" style="grid-column:1/-1">
          {%- if product_filter == 'sealed' -%}
            {%- if source != blank -%}
              No sealed products in this collection yet.
            {%- else -%}
              Add sealed stock, then choose a collection in this section.
            {%- endif -%}
          {%- else -%}
            {%- if source != blank -%}
              No singles in this collection yet.
            {%- else -%}
              Add singles, then choose a collection in this section.
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product showcase",
  "tag": "section",
  "class": "section-product-showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New in the binder"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Fresh stock with live counts - what you see is what is available."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "select",
      "id": "product_filter",
      "label": "Show products",
      "options": [
        { "value": "singles", "label": "Singles only" },
        { "value": "sealed", "label": "Sealed only" },
        { "value": "all", "label": "All products" }
      ],
      "default": "singles"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 16,
      "step": 1,
      "label": "Products",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Product showcase"
    }
  ]
}
{% endschema %}
