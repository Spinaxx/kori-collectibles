{%- liquid
  assign source = section.settings.collection
  assign limit = section.settings.products_to_show | default: 8
  if source != blank
    assign products = source.products
  else
    assign products = collections.all.products
  endif
-%}

<section class="section">
  <div class="page-width">
    <div class="section-head">
      <div>
        <h2>{{ section.settings.heading | escape }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p>{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.show_view_all and source != blank -%}
        <a class="section-link" href="{{ source.url }}">View all</a>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- for product in products limit: limit -%}
        {%- liquid
          assign image_alt = product.featured_image.alt | default: product.title
        -%}
        <a class="card" href="{{ product.url }}">
          <div class="card__media">
            {%- if product.available == false -%}
              <span class="card__badge card__badge--sold">Sold out</span>
            {%- elsif product.tags contains 'preorder' or product.tags contains 'Preorder' or product.tags contains 'pre-order' -%}
              <span class="card__badge">Pre-order</span>
            {%- endif -%}

            {%- if product.featured_image != blank -%}
              <img
                class="card__image"
                src="{{ product.featured_image | image_url: width: 480 }}"
                srcset="
                  {{ product.featured_image | image_url: width: 240 }} 240w,
                  {{ product.featured_image | image_url: width: 360 }} 360w,
                  {{ product.featured_image | image_url: width: 480 }} 480w,
                  {{ product.featured_image | image_url: width: 700 }} 700w
                "
                sizes="(max-width: 749px) 45vw, 23vw"
                alt="{{ image_alt | escape }}"
                width="{{ product.featured_image.width }}"
                height="{{ product.featured_image.height }}"
                loading="lazy"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>

          <div class="card__body">
            <div class="card__title">{{ product.title | escape }}</div>
            <div class="card__footer">
              <span class="card__price">
                {%- if product.price_varies -%}
                  From {{ product.price_min | money }}
                {%- else -%}
                  {{ product.price | money }}
                {%- endif -%}
              </span>
            </div>
          </div>
        </a>
      {%- else -%}
        <div class="empty-state" style="grid-column:1/-1">
          {%- if source != blank -%}
            No products in this collection yet.
          {%- else -%}
            Add products, then choose a collection in this section.
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product showcase",
  "tag": "section",
  "class": "section-product-showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New in the binder"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Fresh stock with live counts - what you see is what is available."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 16,
      "step": 1,
      "label": "Products",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Product showcase"
    }
  ]
}
{% endschema %}
