<section class="page-width cart">
  <h1>{{ 'cart.title' | t }}</h1>

  {%- if cart.item_count == 0 -%}
    <div class="empty-state">
      <p>{{ settings.empty_cart_message }}</p>
      <a class="button" href="{{ routes.all_products_collection_url }}" style="margin-top:1rem;">
        {{ 'general.continue_shopping' | t }}
      </a>
    </div>
  {%- else -%}
    <form action="{{ routes.cart_url }}" method="post">
      <table class="cart-table">
        <thead>
          <tr>
            <th>Product</th>
            <th>Qty</th>
            <th>Total</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {%- for item in cart.items -%}
            <tr>
              <td>
                <div class="cart-item">
                  {%- if item.image -%}
                    {{ item.image | image_url: width: 160 | image_tag: loading: 'lazy', alt: item.product.title }}
                  {%- endif -%}
                  <div>
                    <div class="cart-item__title"><a href="{{ item.url }}">{{ item.product.title }}</a></div>
                    {%- unless item.product.has_only_default_variant -%}
                      <div class="cart-item__meta">{{ item.variant.title }}</div>
                    {%- endunless -%}
                    <div class="cart-item__meta">{{ item.original_price | money }}</div>
                  </div>
                </div>
              </td>
              <td>
                <input class="cart-qty" type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="{{ 'products.quantity' | t }}">
              </td>
              <td class="mono">{{ item.final_line_price | money }}</td>
              <td><a href="{{ item.url_to_remove }}">{{ 'cart.remove' | t }}</a></td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>

      <div class="cart-summary">
        {%- if settings.cart_free_shipping_threshold != blank -%}
          {%- assign threshold = settings.cart_free_shipping_threshold | times: 100 -%}
          {%- if cart.total_price >= threshold -%}
            <div class="free-ship">{{ 'cart.free_shipping_unlocked' | t }}</div>
          {%- else -%}
            {%- assign remaining = threshold | minus: cart.total_price -%}
            {%- assign remaining_money = remaining | money -%}
            <div class="free-ship">{{ 'cart.free_shipping_remaining' | t: amount: remaining_money }}</div>
          {%- endif -%}
        {%- endif -%}

        <div class="cart-summary__row">
          <span>{{ 'cart.subtotal' | t }}</span>
          <strong>{{ cart.total_price | money }}</strong>
        </div>
        <p class="cart-summary__note">{{ 'cart.taxes_and_shipping' | t }}</p>

        {%- if settings.cart_notes_enable -%}
          <label for="CartNote" class="visually-hidden">{{ 'cart.note' | t }}</label>
          <textarea
            id="CartNote"
            name="note"
            placeholder="{{ 'cart.note' | t }}"
            style="width:100%;min-height:90px;margin-bottom:1rem;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.75rem;"
          >{{ cart.note }}</textarea>
        {%- endif -%}

        <div class="cart-actions">
          <button type="submit" name="update" class="button button--secondary">{{ 'cart.update' | t }}</button>
          <button type="submit" name="checkout" class="button">{{ 'cart.checkout' | t }}</button>
        </div>
      </div>
    </form>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
