<section class="page-width empty-state section">
  <h1>{{ shop.name }}</h1>
  <p style="margin:1rem 0;">This shop is password protected.</p>
  {% form 'storefront_password' %}
    {{ form.errors | default_errors }}
    <input
      type="password"
      name="password"
      placeholder="Password"
      class="search-modal__input"
      style="max-width:280px;margin:0 auto 1rem;display:block;"
    >
    <button type="submit" class="button">Enter</button>
  {% endform %}
</section>

{% schema %}
{
  "name": "Password",
  "settings": []
}
{% endschema %}
