{%- liquid
  assign type_lc = product.type | downcase | strip
  assign tags_lc = product.tags | join: ',' | downcase
  assign sealed = false
  if type_lc contains 'sealed' or type_lc contains 'booster' or type_lc contains 'etb' or type_lc contains 'elite trainer' or tags_lc contains 'sealed'
    assign sealed = true
  endif

  assign product_desc = product.description
  if sealed and product_desc != blank
    if product_desc contains '<p><small>Catalog ID:'
      assign product_desc = product_desc | split: '<p><small>Catalog ID:' | first
    elsif product_desc contains '<p><small>catalog id:'
      assign product_desc = product_desc | split: '<p><small>catalog id:' | first
    elsif product_desc contains 'Catalog ID:'
      assign product_desc = product_desc | split: 'Catalog ID:' | first
    endif
  endif

  assign tcg_label = product.vendor | strip
  if tcg_label == blank or tcg_label == 'Trading Card'
    assign tcg_label = blank
  endif

  assign set_name = blank
  if product.metafields.custom.set_name != blank
    assign set_name = product.metafields.custom.set_name.value | default: product.metafields.custom.set_name | strip
  endif
  if set_name == blank and product.title contains ' - '
    assign title_parts = product.title | split: ' - '
    if title_parts.size > 1
      assign set_name = title_parts[1] | strip
    endif
  endif

  assign product_eyebrow = blank
  if tcg_label != blank and set_name != blank
    assign product_eyebrow = tcg_label | append: ' • ' | append: set_name
  elsif tcg_label != blank
    assign product_eyebrow = tcg_label
  elsif set_name != blank
    assign product_eyebrow = set_name
  else
    assign product_eyebrow = product.type | default: 'Kori Collectibles'
  endif
-%}

<section class="page-width">
  <div class="product{% if sealed %} product--sealed{% endif %}">
    <div class="product__media">
      <div class="product__frame">
        {%- if product.featured_media -%}
          {%- assign media_alt = product.featured_media.alt | default: product.title -%}
          {{
            product.featured_media.preview_image
            | image_url: width: 1400
            | image_tag:
              loading: 'eager',
              widths: '400, 600, 800, 1200, 1400',
              sizes: '(max-width: 989px) 90vw, 45vw',
              alt: media_alt
          }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag }}
        {%- endif -%}
      </div>
    </div>

    <div>
      <p class="product__eyebrow">
        {{ product_eyebrow | escape }}
      </p>
      <h1 class="product__title">{{ product.title | escape }}</h1>
      <div class="product__price" data-product-price>
        {%- if product.price_varies -%}
          {{ 'products.from' | t }} {{ product.price_min | money }}
        {%- else -%}
          {{ product.selected_or_first_available_variant.price | money }}
        {%- endif -%}
      </div>

      {%- assign current = product.selected_or_first_available_variant -%}
      {%- if current.inventory_management == 'shopify' -%}
        <p
          class="product__stock{% if current.available and current.inventory_quantity > 0 and current.inventory_quantity <= 3 %} is-low{% endif %}"
          data-product-stock
        >
          {%- if current.available -%}
            {%- if current.inventory_quantity == 1 -%}
              1 in stock
            {%- else -%}
              {{ current.inventory_quantity }} in stock
            {%- endif -%}
          {%- else -%}
            Out of stock
          {%- endif -%}
        </p>
      {%- endif -%}

      {%- if product_desc != blank -%}
        <div class="product__desc">{{ product_desc }}</div>
      {%- endif -%}

      {%- assign product_add_label = 'products.add_to_cart' | t -%}
      {%- assign product_sold_label = 'products.sold_out' | t -%}
      {% form 'product', product, class: 'product-form' %}
        <span class="visually-hidden" data-add-to-cart>{{ product_add_label }}</span>
        <span class="visually-hidden" data-sold-out>{{ product_sold_label }}</span>
        {%- unless product.has_only_default_variant -%}
          <div class="product-form__field">
            <span class="product-form__label" id="VariantLabel-{{ section.id }}">Variant</span>
            <div class="product-form__pills" role="radiogroup" aria-labelledby="VariantLabel-{{ section.id }}">
              {%- for variant in product.variants -%}
                <label class="product-form__pill{% if variant == current %} is-selected{% endif %}{% unless variant.available %} is-unavailable{% endunless %}">
                  <input
                    type="radio"
                    name="id"
                    value="{{ variant.id }}"
                    class="product-form__pill-input"
                    {% if variant == current %}checked{% endif %}
                    {% unless variant.available %}disabled{% endunless %}
                  >
                  <span class="product-form__pill-text">{{ variant.title | escape }}</span>
                </label>
              {%- endfor -%}
            </div>
          </div>
        {%- else -%}
          <input type="hidden" name="id" value="{{ current.id }}">
        {%- endunless -%}

        <div class="product-form__field">
          <label class="product-form__label" for="Quantity-{{ section.id }}">{{ 'products.quantity' | t }}</label>
          <input id="Quantity-{{ section.id }}" type="number" name="quantity" min="1" value="1">
        </div>

        <button
          type="submit"
          class="button button--full"
          data-product-submit
          {% unless current.available %}disabled{% endunless %}
        >
          {%- if current.available -%}
            {{ 'products.add_to_cart' | t }}
          {%- else -%}
            {{ 'products.sold_out' | t }}
          {%- endif -%}
        </button>

        <script type="application/json" data-product-variants>
          {{ product.variants | json }}
        </script>
        <script type="application/json" data-product-inventory>
          {
            {%- for variant in product.variants -%}
              "{{ variant.id }}": {
                "qty": {{ variant.inventory_quantity | default: 0 }},
                "tracked": {% if variant.inventory_management == 'shopify' %}true{% else %}false{% endif %},
                "available": {% if variant.available %}true{% else %}false{% endif %}
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          }
        </script>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product",
  "settings": [],
  "disabled_on": { "groups": ["header", "footer"] }
}
{% endschema %}
