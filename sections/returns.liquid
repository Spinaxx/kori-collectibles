<section class="section returns-page">
  <div class="page-width">
    <div class="returns-page__hero">
      <p class="returns-page__eyebrow">{{ section.settings.eyebrow | default: 'Returns' | escape }}</p>
      <h1 class="returns-page__title">{{ section.settings.heading | default: 'Refund policy' | escape }}</h1>
      {%- if section.settings.intro != blank -%}
        <p class="returns-page__intro">{{ section.settings.intro | escape }}</p>
      {%- else -%}
        <p class="returns-page__intro">We condition-check before packing. If something arrives wrong or damaged, we’ll put it right.</p>
      {%- endif -%}
    </div>

    <div class="returns-page__highlights">
      <div class="returns-page__highlight">
        <span class="returns-page__highlight-label">Window</span>
        <p class="returns-page__highlight-value">{{ section.settings.window | default: '14 days' | escape }}</p>
      </div>
      <div class="returns-page__highlight">
        <span class="returns-page__highlight-label">Damaged / wrong item</span>
        <p class="returns-page__highlight-value">{{ section.settings.damaged_highlight | default: 'We’ll replace or refund' | escape }}</p>
      </div>
      <div class="returns-page__highlight">
        <span class="returns-page__highlight-label">Contact</span>
        <p class="returns-page__highlight-value">{{ section.settings.support_email | default: 'support@koricollectibles.co.uk' | escape }}</p>
      </div>
    </div>

    <div class="returns-page__grid">
      <section class="returns-page__block">
        <h2>{{ section.settings.eligibility_heading | default: 'What you can return' | escape }}</h2>
        <div class="returns-page__copy">
          {%- if section.settings.eligibility_body != blank -%}
            {{ section.settings.eligibility_body }}
          {%- else -%}
            <p>Contact us within {{ section.settings.window | default: '14 days' | escape }} of delivery if:</p>
            <ul>
              <li>The item arrived damaged in transit</li>
              <li>You received the wrong item</li>
              <li>A single’s condition doesn’t match the listing</li>
            </ul>
            <p>Include your order number and clear photos of the item and packaging where relevant.</p>
          {%- endif -%}
        </div>
      </section>

      <section class="returns-page__block">
        <h2>{{ section.settings.exclusions_heading | default: 'What we can’t accept' | escape }}</h2>
        <div class="returns-page__copy">
          {%- if section.settings.exclusions_body != blank -%}
            {{ section.settings.exclusions_body }}
          {%- else -%}
            <ul>
              <li>Sealed product that has been opened or has broken factory seals</li>
              <li>Change-of-mind returns on singles once dispatched (condition is listed clearly before purchase)</li>
              <li>Items returned without prior approval</li>
              <li>Items damaged after delivery through mishandling</li>
            </ul>
            <p>If you’re unsure before ordering, email us and we’ll help.</p>
          {%- endif -%}
        </div>
      </section>

      <section class="returns-page__block">
        <h2>{{ section.settings.process_heading | default: 'How to start a return' | escape }}</h2>
        <div class="returns-page__copy">
          {%- if section.settings.process_body != blank -%}
            {{ section.settings.process_body }}
          {%- else -%}
            <ol>
              <li>Email <a href="mailto:{{ section.settings.support_email | default: 'support@koricollectibles.co.uk' | escape }}">{{ section.settings.support_email | default: 'support@koricollectibles.co.uk' | escape }}</a> with your order number and photos.</li>
              <li>We’ll confirm whether a replacement, refund, or return is needed.</li>
              <li>If a return is approved, we’ll send instructions. Please don’t post anything back until we reply.</li>
            </ol>
            <p>Approved returns should be packed securely so cards and sealed product stay protected in transit.</p>
          {%- endif -%}
        </div>
      </section>

      <section class="returns-page__block">
        <h2>{{ section.settings.refunds_heading | default: 'Refunds' | escape }}</h2>
        <div class="returns-page__copy">
          {%- if section.settings.refunds_body != blank -%}
            {{ section.settings.refunds_body }}
          {%- else -%}
            <p>Once we receive and check an approved return — or once we confirm a damaged/wrong item case — we’ll refund to your original payment method.</p>
            <p>Refunds usually show within a few working days, depending on your bank or card provider.</p>
            <p>Original shipping is only refunded when the return is due to our error or transit damage we accept responsibility for.</p>
          {%- endif -%}
        </div>
      </section>
    </div>

    <p class="returns-page__cta">
      Need help with an order?
      <a href="{{ pages.contact.url | default: '/pages/contact' }}">Contact support</a>
    </p>
  </div>
</section>

