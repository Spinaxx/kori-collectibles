<section class="page-width section">
  <div class="section-head">
    <div>
      <h1>{{ 'search.title' | t }}</h1>
      {%- if search.performed -%}
        {%- if search.results_count == 0 -%}
          <p>{{ 'search.no_results' | t: terms: search.terms }}</p>
        {%- else -%}
          <p>{{ 'search.results_count' | t: count: search.results_count, terms: search.terms }}</p>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

  <form action="{{ routes.search_url }}" method="get" role="search" class="search-modal__form" style="margin-bottom:2rem;">
    <input type="hidden" name="type" value="product">
    <input class="search-modal__input" type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'search.placeholder' | t }}">
    <button type="submit" class="button">{{ 'search.submit' | t }}</button>
  </form>

  {%- if search.performed -%}
    <div class="product-grid">
      {%- paginate search.results by 24 -%}
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {% render 'product-card', product: item %}
          {%- endif -%}
        {%- endfor -%}

        {%- if paginate.pages > 1 -%}
          <div class="pagination" style="grid-column:1/-1">
            {{ paginate | default_pagination }}
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Search",
  "settings": []
}
{% endschema %}
