<section class="page-width section">
  <div class="section-head">
    <div>
      <h1>{{ 'collections.title' | t }}</h1>
    </div>
  </div>
  <div class="game-grid">
    {%- for collection in collections -%}
      {%- unless collection.handle == 'all' -%}
        <a class="game-tile" href="{{ collection.url }}">
          <span class="game-tile__label">{{ collection.title }}</span>
          <span class="game-tile__meta">{{ collection.products_count }} products</span>
        </a>
      {%- endunless -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Collections list",
  "settings": []
}
{% endschema %}
