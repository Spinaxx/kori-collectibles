          ]
        }
      ]
    },
    {
      "type": "more_tcgs",
      "name": "More TCGs expander",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "More TCGs"
        },
        {
          "type": "checkbox",
          "id": "show_title",
          "label": "Show title under logo",
          "default": false
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta",
          "default": "Magic · One Piece · More"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Override logo"
        },
        {
          "type": "select",
          "id": "logo_key",
          "label": "Built-in logo",
          "default": "more_tcgs",
          "options": [
            { "value": "more_tcgs", "label": "More TCGs" },
            { "value": "auto", "label": "Auto from title" }
          ]
        },
        {
          "type": "paragraph",
          "content": "Add TCG sub-tile blocks below this one in the section. They appear when this tile is clicked."
        }
      ]
    },
    {
      "type": "tcg_sub",
      "name": "TCG sub-tile",
      "settings": [
        {
          "type": "header",
          "content": "Coming soon"
        },
        {
          "type": "checkbox",
          "id": "coming_soon",
          "label": "Show coming soon banner",
          "default": true
        },
        {
          "type": "text",
          "id": "coming_soon_text",
          "label": "Banner text",
          "default": "Coming soon"
        },
        {
          "type": "header",
          "content": "Tile content"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Magic"
        },
        {
          "type": "checkbox",
          "id": "show_title",
          "label": "Show title under logo",
          "default": false
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta",
          "default": "Singles · Sealed"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Ignored while Coming soon is enabled."
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Override logo"
        },
        {
          "type": "select",
          "id": "logo_key",
          "label": "Built-in logo",
