  "presets": [
    {
      "name": "Shop by game",
      "blocks": [
        { "type": "game", "settings": { "title": "Pokemon", "meta": "Singles · Sealed", "logo_key": "pokemon", "show_title": false, "coming_soon": false } },
        { "type": "game", "settings": { "title": "Japanese Pokemon", "meta": "Singles · Sealed", "logo_key": "japanese_pokemon", "show_title": true, "coming_soon": false } },
        { "type": "game", "settings": { "title": "Yu-Gi-Oh!", "meta": "Singles · Sealed", "logo_key": "yugioh", "show_title": false, "coming_soon": false } },
        { "type": "game", "settings": { "title": "Lorcana", "meta": "Sealed", "logo_key": "lorcana", "show_title": false, "coming_soon": false } },
