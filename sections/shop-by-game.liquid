<section class="section section--tight">
  <div class="page-width">
    <div class="section-head">
      <div>
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p>{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    </div>
    <div class="game-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'tcg_sub' -%}
          {%- continue -%}
        {%- endif -%}

        {%- if block.type == 'more_tcgs' -%}
          <div class="game-tile-expand" data-more-tcgs>
            {%- render 'game-tile', block: block, tile_mode: 'toggle' -%}
            <div
              class="game-tile-expand__panel"
              id="MoreTcgs-{{ section.id }}"
              data-more-tcgs-panel
              hidden
            >
              <div class="game-tile-expand__subs">
                {%- for sub in section.blocks -%}
                  {%- if sub.type == 'tcg_sub' -%}
                    {%- render 'game-tile', block: sub -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
          </div>
        {%- else -%}
          {%- render 'game-tile', block: block -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop by game",
  "tag": "section",
  "class": "section-shop-by-game",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
