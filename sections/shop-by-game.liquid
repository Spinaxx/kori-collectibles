  "blocks": [
    {
      "type": "game",
      "name": "Game tile",
      "settings": [
        {
          "type": "header",
          "content": "Coming soon"
        },
        {
          "type": "checkbox",
          "id": "coming_soon",
          "label": "Show coming soon banner",
          "default": false
        },
        {
          "type": "text",
          "id": "coming_soon_text",
          "label": "Banner text",
          "default": "Coming soon"
        },
        {
          "type": "header",
          "content": "Tile content"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Pokemon"
        },
        {
          "type": "checkbox",
          "id": "show_title",
          "label": "Show title under logo",
          "default": false
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta",
          "default": "Singles · Sealed"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Ignored while Coming soon is enabled."
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Override logo",
          "info": "Optional. Leave empty to use the built-in official logo."
        },
        {
          "type": "select",
          "id": "logo_key",
          "label": "Built-in logo",
