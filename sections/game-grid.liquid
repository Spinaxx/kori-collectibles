<section class="section section--tight">
  <div class="page-width">
    <div class="section-head">
      <div>
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p>{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    </div>
    <div class="game-grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign logo_key = block.settings.logo_key | default: 'auto'
          if logo_key == 'auto'
            assign title_key = block.settings.title | downcase | strip
            if title_key contains 'pokemon' or title_key contains 'pokémon'
              assign logo_key = 'pokemon'
            elsif title_key contains 'yu-gi' or title_key contains 'yugioh' or title_key contains 'yu gi'
              assign logo_key = 'yugioh'
            elsif title_key contains 'magic' or title_key contains 'mtg'
              assign logo_key = 'magic'
            elsif title_key contains 'one piece'
              assign logo_key = 'onepiece'
            elsif title_key contains 'lorcana'
              assign logo_key = 'lorcana'
            else
              assign logo_key = 'accessories'
            endif
          endif

          case logo_key
            when 'pokemon'
              assign logo_asset = 'logo-pokemon.svg'
            when 'yugioh'
              assign logo_asset = 'logo-yugioh.png'
            when 'magic'
              assign logo_asset = 'logo-magic.svg'
            when 'onepiece'
              assign logo_asset = 'logo-onepiece.svg'
            when 'lorcana'
              assign logo_asset = 'logo-lorcana.svg'
            else
              assign logo_asset = 'logo-accessories.svg'
          endcase
        -%}
        {%- liquid
          assign coming_soon = block.settings.coming_soon
          assign banner_text = block.settings.coming_soon_text | default: 'Coming soon'
          assign tile_href = routes.collections_url
          if block.settings.link != blank
            assign tile_href = block.settings.link
          endif
        -%}
        <a
          class="game-tile{% if coming_soon %} game-tile--coming-soon{% endif %}"
          href="{{ tile_href }}"
          {% if coming_soon %}aria-label="{{ block.settings.title | escape }} — {{ banner_text | escape }}"{% endif %}
          {{ block.shopify_attributes }}
        >
          {%- if coming_soon -%}
            <span class="game-tile__banner" aria-hidden="true">
              <span class="game-tile__banner-text">{{ banner_text | escape }}</span>
            </span>
          {%- endif -%}
          <span class="game-tile__logo" aria-hidden="true">
            {%- if block.settings.logo != blank -%}
              <img
                src="{{ block.settings.logo | image_url: width: 360 }}"
                srcset="{{ block.settings.logo | image_url: width: 180 }} 180w, {{ block.settings.logo | image_url: width: 280 }} 280w, {{ block.settings.logo | image_url: width: 360 }} 360w"
                sizes="120px"
                alt=""
                width="120"
                height="48"
                loading="lazy"
              >
            {%- else -%}
              <img
                src="{{ logo_asset | asset_url }}"
                alt=""
                width="120"
                height="48"
                loading="lazy"
              >
            {%- endif -%}
          </span>
          {%- if block.settings.show_title -%}
            <span class="game-tile__label">{{ block.settings.title | escape }}</span>
          {%- endif -%}
          {%- if block.settings.meta != blank -%}
            <span class="game-tile__meta">{{ block.settings.meta | escape }}</span>
          {%- endif -%}
          <span class="visually-hidden">{{ block.settings.title | escape }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Game grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by game"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Jump straight into the catalogue collectors actually browse."
    }
  ],
  "blocks": [
    {
      "type": "game",
      "name": "Game",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Pokemon"
        },
        {
          "type": "checkbox",
          "id": "show_title",
          "label": "Show title under logo",
          "default": false
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta",
          "default": "Singles · Sealed"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "coming_soon",
          "label": "Show coming soon banner",
          "default": false
        },
        {
          "type": "text",
          "id": "coming_soon_text",
          "label": "Banner text",
          "default": "Coming soon",
          "info": "Shown as a diagonal banner across the tile when enabled."
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Override logo",
          "info": "Optional. Leave empty to use the built-in official logo."
        },
        {
          "type": "select",
          "id": "logo_key",
          "label": "Built-in logo",
          "default": "auto",
          "options": [
            { "value": "auto", "label": "Auto from title" },
            { "value": "pokemon", "label": "Pokemon" },
            { "value": "yugioh", "label": "Yu-Gi-Oh!" },
            { "value": "magic", "label": "Magic" },
            { "value": "onepiece", "label": "One Piece" },
            { "value": "lorcana", "label": "Lorcana" },
            { "value": "accessories", "label": "Accessories" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Game grid",
      "blocks": [
        { "type": "game", "settings": { "title": "Pokemon", "meta": "Singles · Sealed", "logo_key": "pokemon", "show_title": false } },
        { "type": "game", "settings": { "title": "Yu-Gi-Oh!", "meta": "Singles · Sealed", "logo_key": "yugioh", "show_title": false } },
        { "type": "game", "settings": { "title": "Magic", "meta": "Singles · Sealed", "logo_key": "magic", "show_title": false } },
        { "type": "game", "settings": { "title": "One Piece", "meta": "Sealed", "logo_key": "onepiece", "show_title": false } },
        { "type": "game", "settings": { "title": "Lorcana", "meta": "Sealed", "logo_key": "lorcana", "show_title": false } },
        { "type": "game", "settings": { "title": "Accessories", "meta": "Sleeves · Binders", "logo_key": "accessories", "show_title": false } }
      ]
    }
  ]
}
{% endschema %}
