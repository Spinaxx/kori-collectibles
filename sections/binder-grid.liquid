{%- liquid
  assign collection = section.settings.collection
  assign product_limit = section.settings.products_to_show
-%}

<div class="wrap" id="grid" {{ section.shopify_attributes }}>
  <section class="section">
    <div class="section-head">
      <div>
        <h2>{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p>{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    </div>

    <div class="binder-grid">
      {% if collection != blank and collection.products_count > 0 %}
        {% for product in collection.products limit: product_limit %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% else %}
        {% assign demo_cards = 'Emberling:£3.20:3 left:rare,Tidecoil:£1.80:12 left:,Verdant Sprig:£8.50:1 left:rare,Voltling:£2.40:21 left:,Mindglass:£4.10:7 left:,Cinderpup:£1.20:30 left:,Abysshell:£12.00:2 left:rare,Mosswhelp:£0.90:44 left:' | split: ',' %}
        {% for card in demo_cards %}
          {% if card != blank %}
            {% assign parts = card | split: ':' %}
            {% assign name = parts[0] %}
            {% assign price = parts[1] %}
            {% assign stock = parts[2] %}
            {% assign rare = parts[3] %}
            <div class="slot{% if rare == 'rare' %} slot-rare{% endif %}">
              <div class="slot-card">
                <div class="slot-art">
                  <svg viewBox="0 0 100 100" aria-hidden="true">
                    <ellipse cx="50" cy="60" rx="24" ry="20" fill="#3a3b4d"/>
                    <circle cx="42" cy="58" r="4" fill="#f4f1ff"/>
                    <circle cx="58" cy="58" r="4" fill="#f4f1ff"/>
                  </svg>
                </div>
              </div>
              <div class="slot-info">
                <div class="slot-name">{{ name }}</div>
                <div class="slot-set">Demo · sample</div>
              </div>
              <div class="slot-foot">
                <span class="slot-price">{{ price }}</span>
                <span class="slot-stock{% if stock contains '1 ' or stock contains '2 ' or stock contains '3 ' %} low{% endif %}">{{ stock }}</span>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Binder grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New in the binder"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Fresh pulls and fresh stock — condition-checked before they hit the site."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 24,
      "step": 1,
      "label": "Products to show",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Binder grid"
    }
  ]
}
{% endschema %}
