{%- liquid
  assign heading = section.settings.heading | default: page.title | default: 'Shop'
  assign logo_key = section.settings.logo_key | default: 'pokemon'
  case logo_key
    when 'pokemon'
      assign logo_asset = 'logo-pokemon.svg'
    when 'japanese_pokemon'
      assign logo_asset = 'logo-pokemon.svg'
    when 'yugioh'
      assign logo_asset = 'logo-yugioh.png'
    when 'magic'
      assign logo_asset = 'logo-magic.svg'
    when 'onepiece'
      assign logo_asset = 'logo-onepiece.svg'
    when 'lorcana'
      assign logo_asset = 'logo-lorcana.svg'
    when 'accessories'
      assign logo_asset = 'logo-accessories.svg'
    else
      assign logo_asset = 'logo-pokemon.svg'
  endcase

  assign singles = section.settings.singles_collection
  assign sealed = section.settings.sealed_collection
  assign graded = section.settings.graded_collection

  assign filter_param = section.settings.set_filter_param | default: 'filter.p.m.app--373890449409.card_set' | strip
  assign metafield_path = section.settings.set_metafield | default: 'app--373890449409.card_set' | strip
  assign metafield_ns = metafield_path | split: '.' | first
  assign metafield_key = metafield_path | split: '.' | last
  assign max_sets = section.settings.latest_sets_count | default: 3 | plus: 0

  # Build latest-set tiles from:
  # 1) Manual Set blocks (set_name = filter value + optional set banner image)
  # 2) Else auto from product metafield / title on the singles collection
  assign manual_set_count = 0
  for block in section.blocks
    if block.type == 'set' and block.settings.set_name != blank
      assign manual_set_count = manual_set_count | plus: 1
    endif
  endfor

  assign auto_sets = ''
  assign auto_set_count = 0
  assign show_sets = false
-%}

{%- if singles != blank and manual_set_count == 0 and section.settings.auto_latest_sets -%}
  {%- paginate singles.products by 250 -%}
    {%- for product in singles.products -%}
      {%- liquid
        if auto_set_count >= max_sets
          break
        endif

        assign product_set = blank
        if product.metafields[metafield_ns][metafield_key] != blank
          assign product_set = product.metafields[metafield_ns][metafield_key].value | default: product.metafields[metafield_ns][metafield_key] | strip
        endif
        if product_set == blank and product.metafields.custom.set_name != blank
          assign product_set = product.metafields.custom.set_name.value | default: product.metafields.custom.set_name | strip
        endif
        if product_set == blank and product.title contains ' - '
          assign title_parts = product.title | split: ' - '
          if title_parts.size > 1
            assign product_set = title_parts[1] | strip
          endif
        endif

        if product_set == blank
          continue
        endif

        assign set_token = '||' | append: product_set | append: '||'
        unless auto_sets contains set_token
          if auto_sets == blank
            assign auto_sets = set_token
          else
            assign auto_sets = auto_sets | append: product_set | append: '||'
          endif
          assign auto_set_count = auto_set_count | plus: 1
        endunless
      -%}
    {%- endfor -%}
  {%- endpaginate -%}
{%- endif -%}

{%- liquid
  if manual_set_count > 0 or auto_set_count > 0
    assign show_sets = true
  endif
-%}

<section class="section tcg-landing">
  <div class="page-width">
    <div class="tcg-landing__hero">
      <div class="tcg-landing__logo" aria-hidden="true">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 360 }}"
            srcset="{{ section.settings.logo | image_url: width: 180 }} 180w, {{ section.settings.logo | image_url: width: 280 }} 280w, {{ section.settings.logo | image_url: width: 360 }} 360w"
            sizes="160px"
            alt=""
            width="160"
            height="64"
            loading="eager"
          >
        {%- else -%}
          <img
            src="{{ logo_asset | asset_url }}"
            alt=""
            width="160"
            height="64"
            loading="eager"
          >
        {%- endif -%}
      </div>
      {%- if section.settings.eyebrow != blank -%}
        <p class="tcg-landing__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h1 class="tcg-landing__title">{{ heading | escape }}</h1>
      {%- if section.settings.intro != blank -%}
        <p class="tcg-landing__intro">{{ section.settings.intro | escape }}</p>
      {%- elsif page.content != blank -%}
        <div class="tcg-landing__intro rte">{{ page.content }}</div>
      {%- endif -%}
    </div>

    {%- if singles != blank or sealed != blank or graded != blank -%}
      <div class="tcg-landing__band">
        <div class="section-head section-head--inline">
          <h2>{{ section.settings.categories_heading | default: 'Shop by type' | escape }}</h2>
        </div>
        <div class="tcg-landing__categories">
          {%- if singles != blank -%}
            <a class="tcg-landing__card" href="{{ singles.url }}">
              <span class="tcg-landing__card-label">{{ section.settings.singles_label | default: 'Singles' | escape }}</span>
              <span class="tcg-landing__card-meta">
                {%- if section.settings.singles_meta != blank -%}
                  {{ section.settings.singles_meta | escape }}
                {%- else -%}
                  {{ singles.all_products_count }} cards
                {%- endif -%}
              </span>
              <span class="tcg-landing__card-cta">Browse</span>
            </a>
          {%- endif -%}
          {%- if sealed != blank -%}
            <a class="tcg-landing__card" href="{{ sealed.url }}">
              <span class="tcg-landing__card-label">{{ section.settings.sealed_label | default: 'Sealed' | escape }}</span>
              <span class="tcg-landing__card-meta">
                {%- if section.settings.sealed_meta != blank -%}
                  {{ section.settings.sealed_meta | escape }}
                {%- else -%}
                  {{ sealed.all_products_count }} products
                {%- endif -%}
              </span>
              <span class="tcg-landing__card-cta">Browse</span>
            </a>
          {%- endif -%}
          {%- if graded != blank -%}
            <a class="tcg-landing__card" href="{{ graded.url }}">
              <span class="tcg-landing__card-label">{{ section.settings.graded_label | default: 'Graded' | escape }}</span>
              <span class="tcg-landing__card-meta">
                {%- if section.settings.graded_meta != blank -%}
                  {{ section.settings.graded_meta | escape }}
                {%- else -%}
                  {{ graded.all_products_count }} cards
                {%- endif -%}
              </span>
              <span class="tcg-landing__card-cta">Browse</span>
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- if show_sets and singles != blank -%}
      <div class="tcg-landing__band">
        <div class="section-head section-head--inline">
          <h2>{{ section.settings.sets_heading | default: 'Latest sets' | escape }}</h2>
          {%- if section.settings.sets_subheading != blank -%}
            <p>{{ section.settings.sets_subheading | escape }}</p>
          {%- endif -%}
        </div>
        <div class="tcg-landing__sets">
          {%- if manual_set_count > 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type != 'set' -%}{%- continue -%}{%- endif -%}
              {%- assign set_value = block.settings.set_name | strip -%}
              {%- if set_value == blank -%}{%- continue -%}{%- endif -%}
              {%- liquid
                assign set_title = block.settings.title | default: set_value
                assign set_meta = block.settings.meta
                assign set_image = block.settings.image
                assign set_encoded = set_value | url_encode | replace: '%20', '+'
                assign set_url = singles.url | append: '?sort_by=most-relevant&' | append: filter_param | append: '=' | append: set_encoded
              -%}
              <a class="tcg-landing__set" href="{{ set_url }}" {{ block.shopify_attributes }}>
                <span class="tcg-landing__set-media{% if set_image != blank %} tcg-landing__set-media--banner{% endif %}">
                  {%- if set_image != blank -%}
                    <img
                      src="{{ set_image | image_url: width: 800 }}"
                      srcset="{{ set_image | image_url: width: 400 }} 400w, {{ set_image | image_url: width: 600 }} 600w, {{ set_image | image_url: width: 800 }} 800w"
                      sizes="(max-width: 749px) 90vw, 280px"
                      alt="{{ set_title | escape }}"
                      width="{{ set_image.width }}"
                      height="{{ set_image.height }}"
                      loading="lazy"
                    >
                  {%- else -%}
                    <span class="tcg-landing__set-placeholder">{{ set_title | escape }}</span>
                  {%- endif -%}
                </span>
                <span class="tcg-landing__set-body">
                  <span class="tcg-landing__set-title">{{ set_title | escape }}</span>
                  {%- if set_meta != blank -%}
                    <span class="tcg-landing__set-meta">{{ set_meta | escape }}</span>
                  {%- else -%}
                    <span class="tcg-landing__set-meta">Shop singles from this set</span>
                  {%- endif -%}
                  <span class="tcg-landing__card-cta">Shop set</span>
                </span>
              </a>
            {%- endfor -%}
          {%- else -%}
            {%- assign auto_list = auto_sets | remove_first: '||' | split: '||' -%}
            {%- for set_value in auto_list -%}
              {%- if set_value == blank -%}{%- continue -%}{%- endif -%}
              {%- if forloop.index > max_sets -%}{%- break -%}{%- endif -%}
              {%- liquid
                assign set_title = set_value
                assign set_encoded = set_value | url_encode | replace: '%20', '+'
                assign set_url = singles.url | append: '?sort_by=most-relevant&' | append: filter_param | append: '=' | append: set_encoded
              -%}
              <a class="tcg-landing__set" href="{{ set_url }}">
                <span class="tcg-landing__set-media">
                  <span class="tcg-landing__set-placeholder">{{ set_title | escape }}</span>
                </span>
                <span class="tcg-landing__set-body">
                  <span class="tcg-landing__set-title">{{ set_title | escape }}</span>
                  <span class="tcg-landing__set-meta">Shop singles from this set</span>
                  <span class="tcg-landing__card-cta">Shop set</span>
                </span>
              </a>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "TCG landing",
  "tag": "section",
  "class": "section-tcg-landing",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Defaults to the page title if blank."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "Pick a category or jump into the latest sets."
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo override"
    },
    {
      "type": "select",
      "id": "logo_key",
      "label": "Built-in logo",
      "default": "pokemon",
      "options": [
        { "value": "pokemon", "label": "Pokemon" },
        { "value": "japanese_pokemon", "label": "Japanese Pokemon" },
        { "value": "yugioh", "label": "Yu-Gi-Oh!" },
        { "value": "magic", "label": "Magic" },
        { "value": "onepiece", "label": "One Piece" },
        { "value": "lorcana", "label": "Lorcana" },
        { "value": "accessories", "label": "Accessories" }
      ]
    },
    {
      "type": "header",
      "content": "Shop by type"
    },
    {
      "type": "text",
      "id": "categories_heading",
      "label": "Heading",
      "default": "Shop by type"
    },
    {
      "type": "collection",
      "id": "singles_collection",
      "label": "Singles collection"
    },
    {
      "type": "text",
      "id": "singles_label",
      "label": "Singles label",
      "default": "Singles"
    },
    {
      "type": "text",
      "id": "singles_meta",
      "label": "Singles meta",
      "info": "Optional. Defaults to product count."
    },
    {
      "type": "collection",
      "id": "sealed_collection",
      "label": "Sealed collection"
    },
    {
      "type": "text",
      "id": "sealed_label",
      "label": "Sealed label",
      "default": "Sealed"
    },
    {
      "type": "text",
      "id": "sealed_meta",
      "label": "Sealed meta"
    },
    {
      "type": "collection",
      "id": "graded_collection",
      "label": "Graded collection"
    },
    {
      "type": "text",
      "id": "graded_label",
      "label": "Graded label",
      "default": "Graded"
    },
    {
      "type": "text",
      "id": "graded_meta",
      "label": "Graded meta"
    },
    {
      "type": "header",
      "content": "Latest sets"
    },
    {
      "type": "paragraph",
      "content": "Add Set tiles below. Set name must match the collection Set filter (e.g. Chaos Rising). Upload each set’s banner image on the tile — card product photos are not used."
    },
    {
      "type": "text",
      "id": "sets_heading",
      "label": "Heading",
      "default": "Latest sets"
    },
    {
      "type": "text",
      "id": "sets_subheading",
      "label": "Subheading",
      "default": "Jump into the newest releases."
    },
    {
      "type": "checkbox",
      "id": "auto_latest_sets",
      "label": "Auto-detect sets when none are listed",
      "default": true,
      "info": "Only runs if no Set blocks have a set name filled in. Not used on the Pokémon page while Chaos Rising / Perfect Order / Ascended Heroes are listed."
    },
    {
      "type": "range",
      "id": "latest_sets_count",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Auto set count",
      "default": 3
    },
    {
      "type": "text",
      "id": "set_filter_param",
      "label": "Set filter query param",
      "default": "filter.p.m.app--373890449409.card_set",
      "info": "From a filtered collection URL, e.g. filter.p.m.app--….card_set"
    },
    {
      "type": "text",
      "id": "set_metafield",
      "label": "Set metafield (namespace.key)",
      "default": "app--373890449409.card_set",
      "info": "Falls back to custom.set_name, then the set segment in the product title."
    }
  ],
  "blocks": [
    {
      "type": "set",
      "name": "Set tile",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Set banner",
          "info": "Official set logo/banner art for this tile."
        },
        {
          "type": "text",
          "id": "set_name",
          "label": "Set name (filter value)",
          "info": "Exact Set filter value, e.g. Pitch Black or Chaos Rising."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Display title",
          "info": "Optional. Defaults to the set name."
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TCG landing",
      "blocks": [
        { "type": "set", "name": "Set tile" },
        { "type": "set", "name": "Set tile" },
        { "type": "set", "name": "Set tile" }
      ]
    }
  ]
}
{% endschema %}
