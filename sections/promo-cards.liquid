<section class="section section--tight">
  <div class="page-width">
    <div class="section-head">
      <div>
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p>{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    </div>
    <div class="promo-strip">
      {%- for block in section.blocks -%}
        <a class="promo-card" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: block.settings.title }}
          {%- endif -%}
          <div class="promo-card__content">
            <h3>{{ block.settings.title | escape }}</h3>
            {%- if block.settings.text != blank -%}<p>{{ block.settings.text | escape }}</p>{%- endif -%}
            <span class="button button--secondary">{{ block.settings.cta | default: 'Shop now' }}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo cards",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "Shop the vault"},
    {"type": "textarea", "id": "subheading", "label": "Subheading", "default": "Sealed drops, graded cards, and everyday accessories."}
  ],
  "blocks": [
    {
      "type": "promo",
      "name": "Promo",
      "settings": [
        {"type": "image_picker", "id": "image", "label": "Image"},
        {"type": "text", "id": "title", "label": "Title", "default": "Sealed product"},
        {"type": "text", "id": "text", "label": "Text", "default": "ETBs, booster boxes, and collection kits."},
        {"type": "text", "id": "cta", "label": "CTA", "default": "Browse sealed"},
        {"type": "url", "id": "link", "label": "Link"}
      ]
    }
  ],
  "presets": [{
    "name": "Promo cards",
    "blocks": [
      {"type": "promo", "settings": {"title": "Singles", "text": "Condition-checked cards ready to ship.", "cta": "Browse singles"}},
      {"type": "promo", "settings": {"title": "Sealed", "text": "ETBs, boxes, and collections.", "cta": "Browse sealed"}},
      {"type": "promo", "settings": {"title": "Accessories", "text": "Sleeves, binders, and toploaders.", "cta": "Shop accessories"}}
    ]
  }]
}
{% endschema %}
