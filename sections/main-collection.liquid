<section class="page-width">
  <div class="collection-banner" style="padding-top:2rem;">
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p>{{ collection.description | strip_html | truncate: 220 }}</p>
    {%- endif -%}
  </div>

  <div class="collection-layout">
    {%- if collection.filters.size > 0 -%}
      <aside class="facets" data-facets>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;">
          <div class="facets__title">{{ 'collections.filters' | t }}</div>
          <button type="button" class="icon-btn facets-mobile-btn" data-close-facets aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" aria-hidden="true" width="20" height="20">
              <path stroke="currentColor" stroke-linecap="round" stroke-width="1.5" d="M5 5l10 10M15 5 5 15"/>
            </svg>
          </button>
        </div>

        <form>
          {%- for filter in collection.filters -%}
            <details class="facet-group" open>
              <summary>{{ filter.label }}</summary>
              <div class="facet-list">
                {%- case filter.type -%}
                  {%- when 'list', 'boolean' -%}
                    {%- for value in filter.values -%}
                      <label>
                        <input
                          type="checkbox"
                          name="{{ value.param_name }}"
                          value="{{ value.value }}"
                          {% if value.active %}checked{% endif %}
                          {% if value.count == 0 and value.active == false %}disabled{% endif %}
                          onchange="this.form.submit()"
                        >
                        <span>{{ value.label }} ({{ value.count }})</span>
                      </label>
                    {%- endfor -%}
                  {%- when 'price_range' -%}
                    <div style="display:flex;gap:0.5rem;">
                      <input
                        type="number"
                        name="{{ filter.min_value.param_name }}"
                        {% if filter.min_value.value %}value="{{ filter.min_value.value | money_without_currency }}"{% endif %}
                        placeholder="Min"
                        style="width:100%;min-height:42px;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.5rem;"
                      >
                      <input
                        type="number"
                        name="{{ filter.max_value.param_name }}"
                        {% if filter.max_value.value %}value="{{ filter.max_value.value | money_without_currency }}"{% endif %}
                        placeholder="Max"
                        style="width:100%;min-height:42px;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.5rem;"
                      >
                    </div>
                    <button type="submit" class="button button--secondary button--full" style="margin-top:0.65rem;">{{ 'collections.apply' | t }}</button>
                {%- endcase -%}
              </div>
            </details>
          {%- endfor -%}

          {%- if collection.filters.size > 0 -%}
            <a class="section-link" href="{{ collection.url }}" style="display:inline-block;margin-top:1rem;">{{ 'collections.clear' | t }}</a>
          {%- endif -%}
        </form>
      </aside>
    {%- endif -%}

    <div>
      <div class="collection-toolbar">
        <div style="color:var(--muted);font-size:0.88rem;">
          {{ 'collections.product_count' | t: count: collection.products_count }}
        </div>
        <div style="display:flex;gap:0.5rem;align-items:center;">
          {%- if collection.filters.size > 0 -%}
            <button type="button" class="button button--secondary facets-mobile-btn" data-open-facets>
              {{ 'collections.filters' | t }}
            </button>
          {%- endif -%}

          <label class="visually-hidden" for="SortBy">{{ 'collections.sort_by' | t }}</label>
          <select id="SortBy" name="sort_by" onchange="window.location.href=this.value">
            {%- for option in collection.sort_options -%}
              <option
                value="{{ collection.url }}?sort_by={{ option.value }}"
                {% if option.value == collection.sort_by %}selected{% endif %}
              >
                {{ option.name }}
              </option>
            {%- endfor -%}
          </select>
        </div>
      </div>

      <div class="product-grid">
        {%- paginate collection.products by section.settings.products_per_page -%}
          {%- for product in collection.products -%}
            {%- liquid
              assign featured = product.selected_or_first_available_variant
              assign stock = featured.inventory_quantity
              assign low = false
              if stock != blank and stock > 0 and stock <= 5
                assign low = true
              endif
              assign image_alt = product.featured_image.alt | default: product.title
            -%}
            <a class="card" href="{{ product.url }}">
              <div class="card__media">
                {%- unless product.available -%}
                  <span class="card__badge card__badge--sold">Sold out</span>
                {%- elsif product.tags contains 'preorder' or product.tags contains 'Preorder' or product.tags contains 'pre-order' -%}
                  <span class="card__badge">Pre-order</span>
                {%- endif -%}
                {%- if product.featured_image -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 480 }}"
                    srcset="
                      {{ product.featured_image | image_url: width: 240 }} 240w,
                      {{ product.featured_image | image_url: width: 360 }} 360w,
                      {{ product.featured_image | image_url: width: 480 }} 480w,
                      {{ product.featured_image | image_url: width: 700 }} 700w
                    "
                    sizes="(max-width: 749px) 45vw, 23vw"
                    alt="{{ image_alt | escape }}"
                    width="{{ product.featured_image.width }}"
                    height="{{ product.featured_image.height }}"
                    loading="lazy"
                  >
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag }}
                {%- endif -%}
              </div>
              <div class="card__body">
                {%- if product.vendor != blank -%}
                  <div class="card__vendor">{{ product.vendor | escape }}</div>
                {%- endif -%}
                <div class="card__title">{{ product.title | escape }}</div>
                <div class="card__footer">
                  <span class="card__price">
                    {%- if product.price_varies -%}
                      From {{ product.price_min | money }}
                    {%- else -%}
                      {{ product.price | money }}
                    {%- endif -%}
                  </span>
                  {%- if settings.show_stock_count -%}
                    {%- if stock != blank and stock > 0 -%}
                      <span class="card__stock{% if low %} is-low{% endif %}">
                        {%- if low -%}{{ stock }} left{%- else -%}In stock{%- endif -%}
                      </span>
                    {%- elsif product.available == false -%}
                      <span class="card__stock is-low">Sold out</span>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              </div>
            </a>
          {%- else -%}
            <div class="empty-state" style="grid-column:1/-1">No products in this collection yet.</div>
          {%- endfor -%}

          {%- if paginate.pages > 1 -%}
            <div class="pagination" style="grid-column:1/-1">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}">Previous</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}">{{ part.title }}</a>
                {%- else -%}
                  <span class="{% if part.title == paginate.current_page %}current{% endif %}">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}">Next</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 12,
      "max": 48,
      "step": 4,
      "label": "Products per page",
      "default": 24
    }
  ]
}
{% endschema %}
