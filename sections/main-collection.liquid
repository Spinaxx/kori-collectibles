<section class="page-width">
  <div class="collection-banner" style="padding-top:2rem;">
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p>{{ collection.description | strip_html | truncate: 220 }}</p>
    {%- endif -%}
  </div>

  <div class="collection-layout">
    {%- if collection.filters.size > 0 -%}
      <aside class="facets" data-facets>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;">
          <div class="facets__title">{{ 'collections.filters' | t }}</div>
          <button type="button" class="icon-btn facets-mobile-btn" data-close-facets aria-label="{{ 'general.accessibility.close' | t }}">
            {{ 'icon-close.svg' | inline_asset_content }}
          </button>
        </div>

        <form>
          {%- for filter in collection.filters -%}
            <details class="facet-group" open>
              <summary>{{ filter.label }}</summary>
              <div class="facet-list">
                {%- case filter.type -%}
                  {%- when 'list', 'boolean' -%}
                    {%- for value in filter.values -%}
                      <label>
                        <input
                          type="checkbox"
                          name="{{ value.param_name }}"
                          value="{{ value.value }}"
                          {% if value.active %}checked{% endif %}
                          {% if value.count == 0 and value.active == false %}disabled{% endif %}
                          onchange="this.form.submit()"
                        >
                        <span>{{ value.label }} ({{ value.count }})</span>
                      </label>
                    {%- endfor -%}
                  {%- when 'price_range' -%}
                    <div style="display:flex;gap:0.5rem;">
                      <input
                        type="number"
                        name="{{ filter.min_value.param_name }}"
                        {% if filter.min_value.value %}value="{{ filter.min_value.value | money_without_currency }}"{% endif %}
                        placeholder="Min"
                        style="width:100%;min-height:42px;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.5rem;"
                      >
                      <input
                        type="number"
                        name="{{ filter.max_value.param_name }}"
                        {% if filter.max_value.value %}value="{{ filter.max_value.value | money_without_currency }}"{% endif %}
                        placeholder="Max"
                        style="width:100%;min-height:42px;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.5rem;"
                      >
                    </div>
                    <button type="submit" class="button button--secondary button--full" style="margin-top:0.65rem;">{{ 'collections.apply' | t }}</button>
                {%- endcase -%}
              </div>
            </details>
          {%- endfor -%}

          {%- if collection.filters.size > 0 -%}
            <a class="section-link" href="{{ collection.url }}" style="display:inline-block;margin-top:1rem;">{{ 'collections.clear' | t }}</a>
          {%- endif -%}
        </form>
      </aside>
    {%- endif -%}

    <div>
      <div class="collection-toolbar">
        <div style="color:var(--muted);font-size:0.88rem;">
          {{ 'collections.product_count' | t: count: collection.products_count }}
        </div>
        <div style="display:flex;gap:0.5rem;align-items:center;">
          {%- if collection.filters.size > 0 -%}
            <button type="button" class="button button--secondary facets-mobile-btn" data-open-facets>
              {{ 'collections.filters' | t }}
            </button>
          {%- endif -%}

          <label class="visually-hidden" for="SortBy">{{ 'collections.sort_by' | t }}</label>
          <select id="SortBy" name="sort_by" onchange="window.location.href=this.value">
            {%- for option in collection.sort_options -%}
              <option
                value="{{ collection.url }}?sort_by={{ option.value }}"
                {% if option.value == collection.sort_by %}selected{% endif %}
              >
                {{ option.name }}
              </option>
            {%- endfor -%}
          </select>
        </div>
      </div>

      <div class="product-grid">
        {%- paginate collection.products by section.settings.products_per_page -%}
          {%- for product in collection.products -%}
            {% render 'product-card', product: product %}
          {%- else -%}
            <div class="empty-state" style="grid-column:1/-1">{{ 'collections.empty' | t }}</div>
          {%- endfor -%}

          {%- if paginate.pages > 1 -%}
            <div class="pagination" style="grid-column:1/-1">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}">{{ 'general.pagination.previous' | t }}</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}">{{ part.title }}</a>
                {%- else -%}
                  <span class="{% if part.title == paginate.current_page %}current{% endif %}">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}">{{ 'general.pagination.next' | t }}</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 12,
      "max": 48,
      "step": 4,
      "label": "Products per page",
      "default": 24
    }
  ]
}
{% endschema %}
