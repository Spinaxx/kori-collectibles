{%- assign collection = section.settings.collection -%}
{%- assign limit = section.settings.products_to_show | default: 8 -%}

<section class="section">
  <div class="page-width">
    <div class="section-head">
      <div>
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p>{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.show_view_all and collection != blank -%}
        <a class="section-link" href="{{ collection.url }}">View all</a>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: limit -%}
          {% render 'product-card', product: product %}
        {%- else -%}
          <div class="empty-state" style="grid-column:1/-1">{{ 'collections.empty' | t }}</div>
        {%- endfor -%}
      {%- else -%}
        {%- for product in collections.all.products limit: limit -%}
          {% render 'product-card', product: product %}
        {%- else -%}
          <div class="empty-state" style="grid-column:1/-1">Add products, then choose a collection in this section.</div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "New in the binder"},
    {"type": "textarea", "id": "subheading", "label": "Subheading", "default": "Fresh stock with live counts — what you see is what’s available."},
    {"type": "collection", "id": "collection", "label": "Collection"},
    {"type": "range", "id": "products_to_show", "min": 4, "max": 16, "step": 1, "label": "Products", "default": 8},
    {"type": "checkbox", "id": "show_view_all", "label": "Show view all", "default": true}
  ],
  "presets": [{"name": "Featured collection"}]
}
{% endschema %}
