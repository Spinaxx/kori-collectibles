{%- liquid
  assign min_price_pounds = section.settings.min_price | default: 5
  assign min_price_cents = min_price_pounds | times: 100
  assign source = section.settings.source_collection
  assign pool_limit = section.settings.pool_size | default: 50
  assign candidate_count = 0

  if source != blank
    assign product_list = source.products
  else
    assign product_list = collections.all.products
  endif
-%}

<section class="hero wrap" {{ section.shopify_attributes }}>
  <div>
    {% if section.settings.eyebrow != blank %}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}
    <h1>
      {{ section.settings.heading_line_1 }}
      {% if section.settings.heading_line_2 != blank %}
        <br>
        {{ section.settings.heading_line_2 }}
        {% if section.settings.heading_em != blank %}
          <em>{{ section.settings.heading_em }}</em>
        {% endif %}
        {{ section.settings.heading_after }}
      {% endif %}
    </h1>
    {% if section.settings.text != blank %}
      <p class="hero__text">{{ section.settings.text }}</p>
    {% endif %}
    <div class="hero-actions">
      {% if section.settings.primary_label != blank %}
        <a href="{{ section.settings.primary_link }}" class="btn-primary">{{ section.settings.primary_label }}</a>
      {% endif %}
      {% if section.settings.secondary_label != blank %}
        <a href="{{ section.settings.secondary_link }}" class="btn-ghost">{{ section.settings.secondary_label }}</a>
      {% endif %}
    </div>
  </div>

  <div class="tilt-stage">
    <a
      class="tilt-card"
      id="tiltCard"
      href="{{ routes.all_products_collection_url }}"
      data-hero-card
      aria-label="Featured single"
    >
      <div class="tilt-shine" id="tiltShine"></div>
      <img
        data-hero-image
        class="tilt-card__image"
        alt="{{ section.settings.fallback_name | escape }}"
        width="280"
        height="392"
        {% if section.settings.fallback_image != blank %}
          src="{{ section.settings.fallback_image | image_url: width: 800 }}"
        {% else %}
          src=""
          hidden
        {% endif %}
      >
      <div
        class="tilt-card__placeholder"
        data-hero-fallback
        aria-hidden="true"
        {% if section.settings.fallback_image != blank %}hidden{% endif %}
      >
        <svg viewBox="0 0 100 100">
          <ellipse cx="50" cy="58" rx="26" ry="22" fill="#3c2a52"/>
          <path d="M24 45 L10 20 L34 34 Z" fill="#5a3d78"/>
          <path d="M76 45 L90 20 L66 34 Z" fill="#5a3d78"/>
          <circle cx="40" cy="55" r="5" fill="#f4f1ff"/>
          <circle cx="60" cy="55" r="5" fill="#f4f1ff"/>
          <path d="M38 70 Q50 78 62 70" stroke="#f4f1ff" stroke-width="3" fill="none" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="holo-sweep"></div>
    </a>
  </div>

  <script type="application/json" data-hero-candidates>
    [
      {%- for product in product_list -%}
        {%- if candidate_count >= pool_limit -%}
          {%- break -%}
        {%- endif -%}

        {%- liquid
          assign type_down = product.type | downcase | strip
          assign tags_joined = product.tags | join: ',' | downcase

          assign is_sealed = false
          if type_down contains 'sealed' or type_down contains 'booster' or type_down == 'etb' or type_down contains 'elite trainer' or type_down contains 'bundle' or type_down contains 'tin' or type_down contains 'case'
            assign is_sealed = true
          endif
          if tags_joined contains 'sealed' or tags_joined contains 'booster-box' or tags_joined contains 'etb'
            assign is_sealed = true
          endif

          assign is_single = false
          if source != blank and is_sealed == false
            assign is_single = true
          elsif type_down == 'single' or type_down == 'singles' or type_down == 'card' or type_down == 'cards'
            assign is_single = true
          elsif tags_joined contains 'single' or tags_joined contains 'singles'
            assign is_single = true
          endif

          if is_sealed
            assign is_single = false
          endif
        -%}

        {%- if is_single and product.available and product.price > min_price_cents and product.featured_image -%}
          {%- assign candidate_count = candidate_count | plus: 1 -%}
          {%- unless candidate_count == 1 -%},{%- endunless -%}
          {
            "title": {{ product.title | json }},
            "url": {{ product.url | json }},
            "image": {{ product.featured_image | image_url: width: 800 | json }}
          }
        {%- endif -%}
      {%- endfor -%}
    ]
  </script>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Independent Pokémon TCG shop"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading line 1",
      "default": "The hunt is"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading line 2 (before highlight)",
      "default": "half the "
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading highlight",
      "default": "foil"
    },
    {
      "type": "text",
      "id": "heading_after",
      "label": "Heading (after highlight)",
      "default": "."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Supporting text",
      "default": "Singles, sealed product, and grading — sourced and condition-checked by people who actually play. No mystery packs, no guesswork on stock."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Browse singles"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Shop sealed product"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Featured single"
    },
    {
      "type": "collection",
      "id": "source_collection",
      "label": "Singles collection",
      "info": "Recommended: pick your Singles collection. Only available singles over the minimum price are used."
    },
    {
      "type": "range",
      "id": "min_price",
      "min": 1,
      "max": 50,
      "step": 1,
      "unit": "£",
      "label": "Minimum price",
      "default": 5
    },
    {
      "type": "range",
      "id": "pool_size",
      "min": 10,
      "max": 50,
      "step": 5,
      "label": "Candidate pool size",
      "default": 50
    },
    {
      "type": "header",
      "content": "Fallback"
    },
    {
      "type": "text",
      "id": "fallback_name",
      "label": "Fallback alt text",
      "default": "Featured single"
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Fallback card image",
      "info": "Used only when no eligible singles are found."
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
