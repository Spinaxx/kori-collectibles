{%- liquid
  assign min_cents = section.settings.min_price | default: 5 | times: 100
  assign source = section.settings.source_collection
  assign limit = section.settings.pool_size | default: 50
  assign handles = ''
  assign handle_count = 0

  if source != blank
    assign list = source.products
  else
    assign list = collections.all.products
  endif

  for product in list
    if handle_count >= limit
      break
    endif

    assign type = product.type | downcase | strip
    assign tags = product.tags | join: ',' | downcase
    assign sealed = false
    if type contains 'sealed' or type contains 'booster' or type contains 'etb' or type contains 'elite trainer' or tags contains 'sealed'
      assign sealed = true
    endif

    if product.available and product.featured_image != blank and product.price >= min_cents and sealed == false
      if handles == blank
        assign handles = product.handle
      else
        assign handles = handles | append: ',' | append: product.handle
      endif
      assign handle_count = handle_count | plus: 1
    endif
  endfor

  assign hero_product = nil
  if handle_count > 0
    assign handle_list = handles | split: ','
    assign seed = 'now' | date: '%S' | plus: 0
    assign idx = seed | modulo: handle_count
    assign chosen_handle = handle_list[idx]
    assign hero_product = all_products[chosen_handle]
  endif

  if hero_product == blank or hero_product.featured_image == blank
    for product in list
      if product.featured_image != blank and product.available and product.price >= min_cents
        assign hero_product = product
        break
      endif
    endfor
  endif

  if hero_product == blank or hero_product.featured_image == blank
    for product in collections.all.products
      if product.featured_image != blank
        assign hero_product = product
        break
      endif
    endfor
  endif
-%}

<section class="hero">
  <div class="page-width hero__grid">
    <div class="hero__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h1 class="hero__title">
        {{ section.settings.heading_line_1 | escape }}
        {%- if section.settings.heading_line_2 != blank -%}
          <br>{{ section.settings.heading_line_2 | escape -}}
          {%- if section.settings.heading_em != blank -%}<em>{{ section.settings.heading_em | escape }}</em>{%- endif -%}
          {{- section.settings.heading_after | escape -}}
        {%- endif -%}
      </h1>
      {%- if section.settings.text != blank -%}
        <p class="hero__text">{{ section.settings.text | escape }}</p>
      {%- endif -%}
      <div class="hero__actions">
        {%- if section.settings.primary_label != blank -%}
          <a
            class="button"
            href="{% if section.settings.primary_link != blank %}{{ section.settings.primary_link }}{% else %}{{ routes.all_products_collection_url }}{% endif %}"
          >
            {{ section.settings.primary_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          <a
            class="button button--secondary"
            href="{% if section.settings.secondary_link != blank %}{{ section.settings.secondary_link }}{% else %}{{ routes.collections_url }}{% endif %}"
          >
            {{ section.settings.secondary_label | escape }}
          </a>
        {%- endif -%}
      </div>
      <div class="hero__stats">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="hero__stat" {{ block.shopify_attributes }}>
              <strong>{{ block.settings.label | escape }}</strong>
              <span>{{ block.settings.text | escape }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="hero__stage">
      {%- if hero_product != blank and hero_product.featured_image -%}
        <a
          class="hero-card"
          href="{{ hero_product.url }}"
          aria-label="{{ hero_product.title | escape }}"
          data-hero-card
        >
          <span class="hero-card__shine" data-hero-shine></span>
          {%- assign hero_alt = hero_product.featured_image.alt | default: hero_product.title -%}
          <img
            class="hero-card__image"
            src="{{ hero_product.featured_image | image_url: width: 700 }}"
            srcset="
              {{ hero_product.featured_image | image_url: width: 280 }} 280w,
              {{ hero_product.featured_image | image_url: width: 400 }} 400w,
              {{ hero_product.featured_image | image_url: width: 560 }} 560w,
              {{ hero_product.featured_image | image_url: width: 700 }} 700w,
              {{ hero_product.featured_image | image_url: width: 900 }} 900w
            "
            sizes="(max-width: 749px) 70vw, 280px"
            width="{{ hero_product.featured_image.width }}"
            height="{{ hero_product.featured_image.height }}"
            alt="{{ hero_alt | escape }}"
            loading="eager"
            fetchpriority="high"
          >
          <span class="hero-card__holo" aria-hidden="true"></span>
        </a>
      {%- elsif section.settings.fallback_image != blank -%}
        <div class="hero-card" aria-hidden="true">
          <span class="hero-card__shine"></span>
          {{
            section.settings.fallback_image
            | image_url: width: 900
            | image_tag: class: 'hero-card__image', alt: 'Featured card', loading: 'eager'
          }}
          <span class="hero-card__holo"></span>
        </div>
      {%- else -%}
        <div class="hero-card" aria-hidden="true">
          <div class="hero-card__placeholder">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {"type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "UK Pokémon & TCG shop"},
    {"type": "text", "id": "heading_line_1", "label": "Heading line 1", "default": "The hunt is"},
    {"type": "text", "id": "heading_line_2", "label": "Heading line 2", "default": "half the "},
    {"type": "text", "id": "heading_em", "label": "Highlight", "default": "foil"},
    {"type": "text", "id": "heading_after", "label": "After highlight", "default": "."},
    {"type": "textarea", "id": "text", "label": "Text", "default": "Singles and sealed, priced for collectors. Condition-checked under lamp — no mystery packs, no guesswork on stock."},
    {"type": "text", "id": "primary_label", "label": "Primary CTA", "default": "Shop singles"},
    {"type": "url", "id": "primary_link", "label": "Primary link"},
    {"type": "text", "id": "secondary_label", "label": "Secondary CTA", "default": "Browse sealed"},
    {"type": "url", "id": "secondary_link", "label": "Secondary link"},
    {"type": "collection", "id": "source_collection", "label": "Singles collection for hero card", "info": "Recommended. If empty, uses available products over the minimum price."},
    {"type": "image_picker", "id": "fallback_image", "label": "Fallback card image"},
    {"type": "range", "id": "min_price", "min": 0, "max": 50, "step": 1, "label": "Minimum price (GBP)", "default": 5},
    {"type": "range", "id": "pool_size", "min": 10, "max": 50, "step": 5, "label": "Candidate pool", "default": 50}
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {"type": "text", "id": "label", "label": "Label", "default": "Same-week dispatch"},
        {"type": "text", "id": "text", "label": "Text", "default": "Orders before 2pm"}
      ]
    }
  ],
  "presets": [{"name": "Hero", "blocks": [{"type": "stat", "settings": {"label": "Free UK delivery", "text": "Over GBP 40"}}, {"type": "stat", "settings": {"label": "Condition first", "text": "Checked under lamp"}}, {"type": "stat", "settings": {"label": "Real stock", "text": "Live inventory counts"}}]}]
}
{% endschema %}
