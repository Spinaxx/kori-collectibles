{%- liquid
  assign min_price_pounds = section.settings.min_price | default: 5
  assign min_price_cents = min_price_pounds | times: 100
  assign source = section.settings.source_collection
  assign pool_limit = section.settings.pool_size | default: 50
  assign candidate_count = 0

  if source != blank
    assign product_list = source.products
  else
    assign product_list = collections.all.products
  endif
-%}

<section class="hero wrap" {{ section.shopify_attributes }}>
  <div>
    {% if section.settings.eyebrow != blank %}
      <div class="eyebrow">{{ section.settings.eyebrow }}</div>
    {% endif %}
    <h1>
      {{ section.settings.heading_line_1 }}
      {% if section.settings.heading_line_2 != blank %}
        <br>
        {{ section.settings.heading_line_2 }}
        {% if section.settings.heading_em != blank %}
          <em>{{ section.settings.heading_em }}</em>
        {% endif %}
        {{ section.settings.heading_after }}
      {% endif %}
    </h1>
    {% if section.settings.text != blank %}
      <p class="hero__text">{{ section.settings.text }}</p>
    {% endif %}
    <div class="hero-actions">
      {% if section.settings.primary_label != blank %}
        <a href="{{ section.settings.primary_link }}" class="btn-primary">{{ section.settings.primary_label }}</a>
      {% endif %}
      {% if section.settings.secondary_label != blank %}
        <a href="{{ section.settings.secondary_link }}" class="btn-ghost">{{ section.settings.secondary_label }}</a>
      {% endif %}
    </div>
  </div>

  <div class="tilt-stage">
    <a
      class="tilt-card"
      id="tiltCard"
      href="{{ routes.all_products_collection_url }}"
      data-hero-card
      aria-label="Featured card"
    >
      <div class="tilt-shine" id="tiltShine"></div>
      <div class="tilt-inner">
        <div class="tilt-top">
          <span class="tilt-name" data-hero-name>{{ section.settings.fallback_name }}</span>
          <span class="tilt-hp" data-hero-price>{{ section.settings.fallback_price }}</span>
        </div>
        <div class="tilt-art">
          <div class="holo-sweep"></div>
          <img
            data-hero-image
            class="tilt-art__img"
            src=""
            alt=""
            width="252"
            height="280"
            hidden
          >
          <svg data-hero-fallback class="tilt-art__fallback" viewBox="0 0 100 100" aria-hidden="true">
            <ellipse cx="50" cy="58" rx="26" ry="22" fill="#3c2a52"/>
            <path d="M24 45 L10 20 L34 34 Z" fill="#5a3d78"/>
            <path d="M76 45 L90 20 L66 34 Z" fill="#5a3d78"/>
            <circle cx="40" cy="55" r="5" fill="#f4f1ff"/>
            <circle cx="60" cy="55" r="5" fill="#f4f1ff"/>
            <path d="M38 70 Q50 78 62 70" stroke="#f4f1ff" stroke-width="3" fill="none" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="tilt-bottom">
          <div class="tilt-desc" data-hero-desc>{{ section.settings.fallback_desc }}</div>
          <div class="tilt-set" data-hero-set>{{ section.settings.fallback_set }}</div>
        </div>
      </div>
    </a>
  </div>

  <script type="application/json" data-hero-candidates>
    [
      {%- for product in product_list -%}
        {%- if candidate_count >= pool_limit -%}
          {%- break -%}
        {%- endif -%}
        {%- if product.available and product.price > min_price_cents and product.featured_image -%}
          {%- liquid
            assign set_code = product.metafields.custom.set_code
            if set_code == blank
              assign set_code = product.vendor
            endif
            assign desc = product.description | strip_html | truncate: 120
            if desc == blank
              assign desc = product.type | default: 'In stock at Kori Collectibles'
            endif
            assign candidate_count = candidate_count | plus: 1
          -%}
          {%- unless candidate_count == 1 -%},{%- endunless -%}
          {
            "title": {{ product.title | json }},
            "url": {{ product.url | json }},
            "image": {{ product.featured_image | image_url: width: 600 | json }},
            "price": {{ product.price | money | json }},
            "set": {{ set_code | json }},
            "desc": {{ desc | json }}
          }
        {%- endif -%}
      {%- endfor -%}
    ]
  </script>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Independent Pokémon TCG shop"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading line 1",
      "default": "The hunt is"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading line 2 (before highlight)",
      "default": "half the "
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading highlight",
      "default": "foil"
    },
    {
      "type": "text",
      "id": "heading_after",
      "label": "Heading (after highlight)",
      "default": "."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Supporting text",
      "default": "Singles, sealed product, and grading — sourced and condition-checked by people who actually play. No mystery packs, no guesswork on stock."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Browse singles"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Shop sealed product"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Featured card"
    },
    {
      "type": "collection",
      "id": "source_collection",
      "label": "Product source",
      "info": "Leave blank to use all products. Only in-stock items above the minimum price are eligible."
    },
    {
      "type": "range",
      "id": "min_price",
      "min": 1,
      "max": 50,
      "step": 1,
      "unit": "£",
      "label": "Minimum price",
      "default": 5,
      "info": "Hero card is picked at random from available inventory above this price."
    },
    {
      "type": "range",
      "id": "pool_size",
      "min": 10,
      "max": 50,
      "step": 5,
      "label": "Candidate pool size",
      "default": 50,
      "info": "Shopify only exposes the first page of a collection here — keep this at 50 or less."
    },
    {
      "type": "header",
      "content": "Fallback card"
    },
    {
      "type": "text",
      "id": "fallback_name",
      "label": "Fallback name",
      "default": "Duskwing",
      "info": "Shown only when no products meet the criteria."
    },
    {
      "type": "text",
      "id": "fallback_price",
      "label": "Fallback price label",
      "default": "£—"
    },
    {
      "type": "textarea",
      "id": "fallback_desc",
      "label": "Fallback description",
      "default": "Add in-stock products over £5 to power the hero card."
    },
    {
      "type": "text",
      "id": "fallback_set",
      "label": "Fallback set code",
      "default": "Kori Collectibles"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
