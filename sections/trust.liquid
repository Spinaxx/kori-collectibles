<div class="trust" id="trust" {{ section.shopify_attributes }}>
  <div class="wrap">
    <div class="trust-grid">
      {% for block in section.blocks %}
        <div class="trust-item" {{ block.shopify_attributes }}>
          {% if block.settings.number != blank %}
            <span class="trust-num">{{ block.settings.number }}</span>
          {% endif %}
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust strip",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Every single, checked twice"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Condition graded under lamp against our own reference sheet before it hits the shelf or the site."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust strip",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "number": "01",
            "heading": "Every single, checked twice",
            "text": "Condition graded under lamp against our own reference sheet before it hits the shelf or the site."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "number": "02",
            "heading": "We buy collections",
            "text": "Bring in a binder or a bulk box — cash or store credit, quoted while you wait."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "number": "03",
            "heading": "Grading drop-off in store",
            "text": "Submit through us for better turnaround than mailing in solo, tracked from drop-off to return."
          }
        }
      ]
    }
  ]
}
{% endschema %}
